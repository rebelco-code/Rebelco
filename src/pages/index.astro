							<button class="qty-dec" data-pid="rooibos">-</button>
							<span class="qty-count" id="qty-val-rooibos">1</span>
							<button class="qty-inc" data-pid="rooibos">+</button>
						</div>
						<button class="add-btn" data-name="Rooibos & Tea Tree" data-pid="rooibos">
							<span class="add-label">ADD TO ORDER</span>
							<span class="add-ok">✓ ADDED</span>
						</button>
					</div>
					<button class="ing-open mobile-only" data-modal="modal-rooibos">SEE INGREDIENTS</button>
				</div>
				<div class="side-panel desktop-only">
					<h3 class="ing-title">INGREDIENTS</h3>
					<p class="ing-text">NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, ROOIBOS, TEA TREE</p>
