						<!-- ALOE & ROSEMARY SOAP -->
						<div class="product-card">
							<div class="rebel-stamp">Rebel</div>
							<div class="card-img-wrap">
								<img src="/canva_slide_8.png" alt="Aloe and Rosemary Soap" class="label-photo"/>
							</div>
							<div class="card-bottom">
								<h3 class="prod-title">Aloe & Rosemary</h3>
								<p class="price">R100</p>
								<div class="qty-control">
									<button onclick="document.getElementById('q-aloe').innerText = Math.max(1, parseInt(document.getElementById('q-aloe').innerText)-1)">-</button>
