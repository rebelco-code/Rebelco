---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL TALLOW CO. | Natural Rebellion">
	<!-- Film Grain Overlay -->
	<div class="film-grain"></div>

	<!-- Header Nav -->
	<header class="main-header" id="main-header">
		<div class="header-inner">
			<div class="header-left">
				<a href="/" class="skull-logo-link">
					<!-- SVG Skull Logo placeholder to match mockup -->
					<svg class="skull-logo" viewBox="0 0 100 100" fill="var(--gold-light)">
						<path d="M50 8C35 8 20 18 10 30c0 0 15-5 30-2 0 0-5 20-5 35 0 0 5 15 15 25 10-10 15-25 15-25 0-15-5-35-5-35 15-3 30 2 30 2-10-12-25-22-40-22zm-5 45c-2 0-3-2-3-4s1-4 3-4 3 2 3 4-1 4-3 4zm10 0c-2 0-3-2-3-4s1-4 3-4 3 2 3 4-1 4-3 4z"/>
					</svg>
				</a>
			</div>
			<div class="header-center">
				<a href="/" class="logo-text">REBEL TALLOW CO.</a>
			</div>
			<div class="header-right">
				<nav class="desktop-nav">
					<a href="#shop">SHOP</a>
					<a href="#rebellion">THE REBELLION</a>
					<a href="#markets">MARKETS</a>
				</nav>
				<button id="cart-open" class="cart-btn">
					<svg viewBox="0 0 24 24" fill="none" class="cart-icon" stroke="currentColor" stroke-width="2">
						<path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.2 9.3a1 1 0 001 1.2h13.4a1 1 0 001-1.2L17 13M9 18h6" />
					</svg>
					<span id="cart-tally" class="tally-badge">0</span>
				</button>
			</div>
		</div>
	</header>

	<main class="scroll-container">
		<!-- HERO SECTION -->
		<section class="hero-section" id="home">
			<div class="hero-bg"></div>
			<div class="smoke-overlay"></div>
			<div class="hero-content">
				<div class="hero-skull-wrapper">
					<!-- You would ideally use a transparent skull graphic here, using standard unsplash for now tinted -->
					<img src="https://images.unsplash.com/photo-1542382257-80ddbfc7478d?auto=format&fit=crop&q=80&w=1000" alt="Massive Skull" class="hero-skull-img" />
				</div>
				<h1 class="logo-text-huge">REBEL TALLOW CO.</h1>
				<h2 class="hero-slogan">Rebel Against the Processed.<br/>Return to Pure South African Roots.</h2>
				<div class="hero-actions">
					<a href="#shop" class="gold-btn btn-solid">SHOP NOW</a>
					<a href="#rebellion" class="gold-btn btn-outline">DISCOVER OUR STORY</a>
				</div>
			</div>
		</section>

		<!-- SPLIT LAYOUT: REBELLION & SHOP -->
		<section class="split-section">
			<div class="split-left" id="rebellion">
				<div class="rebellion-content">
					<h2 class="section-title logo-text-large">The Rebellion</h2>
					<p class="rebellion-sub">REBEL AGAINST THE PROCESSED. RETURN<br/>TO PURE SOUTH AFRICAN ROOTS.</p>
					<img src="https://images.unsplash.com/photo-1629853381617-6d601dff7244?auto=format&fit=crop&q=80&w=600" alt="Skull" class="rebellion-skull"/>
				</div>
			</div>

			<div class="split-right" id="shop">
				<div class="shop-wood-bg"></div>
				<div class="shop-content">
					<h2 class="section-title logo-text-large">Shop</h2>
					
					<div class="shop-grid">
						<!-- PURE TALLOW -->
						<div class="product-card">
							<div class="rebel-stamp">Rebel</div>
							<div class="card-img-wrap">
                                <!-- Replaced with a more generic skincare jar that works. -->
								<img src="https://images.unsplash.com/photo-1608248593842-8021f11c7fb8?auto=format&fit=crop&q=80&w=400" alt="Pure Tallow Jar"/>
							</div>
							<div class="card-bottom">
								<h3 class="prod-title">Pure Tallow</h3>
								<p class="price">R180</p>
								<div class="qty-control">
									<button onclick="document.getElementById('q-tallow').innerText = Math.max(1, parseInt(document.getElementById('q-tallow').innerText)-1)">-</button>
									<span id="q-tallow">1</span>
									<button onclick="document.getElementById('q-tallow').innerText = parseInt(document.getElementById('q-tallow').innerText)+1">+</button>
								</div>
								<button class="add-crate-btn" data-id="tallow" data-name="Pure Beef Tallow 500ml" data-price="180">Add to Crate</button>
							</div>
						</div>

						<!-- CHARCOAL SOAP -->
						<div class="product-card">
							<div class="rebel-stamp">Rebel</div>
							<div class="card-img-wrap">
								<img src="/charcoal_turmeric_hero.png" alt="Charcoal Soap"/>
							</div>
							<div class="card-bottom">
								<h3 class="prod-title">Charcoal Soap</h3>
								<p class="price">R100</p>
								<div class="qty-control">
									<button onclick="document.getElementById('q-charcoal').innerText = Math.max(1, parseInt(document.getElementById('q-charcoal').innerText)-1)">-</button>
									<span id="q-charcoal">1</span>
									<button onclick="document.getElementById('q-charcoal').innerText = parseInt(document.getElementById('q-charcoal').innerText)+1">+</button>
								</div>
								<button class="add-crate-btn" data-id="charcoal" data-name="Charcoal Soap" data-price="100">Add to Crate</button>
							</div>
						</div>

						<!-- ROOIBOS SOAP -->
						<div class="product-card">
							<div class="rebel-stamp">Rebel</div>
							<div class="card-img-wrap">
								<img src="/rooibos_hero.png" alt="Rooibos Soap"/>
							</div>
							<div class="card-bottom">
								<h3 class="prod-title">Rooibos Soap</h3>
								<p class="price">R100</p>
								<div class="qty-control">
									<button onclick="document.getElementById('q-rooibos').innerText = Math.max(1, parseInt(document.getElementById('q-rooibos').innerText)-1)">-</button>
									<span id="q-rooibos">1</span>
									<button onclick="document.getElementById('q-rooibos').innerText = parseInt(document.getElementById('q-rooibos').innerText)+1">+</button>
								</div>
								<button class="add-crate-btn" data-id="rooibos" data-name="Rooibos Soap" data-price="100">Add to Crate</button>
							</div>
						</div>

						<!-- SKILLET -->
						<div class="product-card">
							<div class="rebel-stamp">Rebel</div>
							<div class="card-img-wrap">
								<img src="https://images.unsplash.com/photo-1544148103-0773bf10d330?auto=format&fit=crop&q=80&w=400" alt="Cast Iron Skillet"/>
							</div>
							<div class="card-bottom">
								<h3 class="prod-title">Seasoned Skillet</h3>
								<p class="price">R180</p>
								<div class="qty-control">
									<button onclick="document.getElementById('q-skillet').innerText = Math.max(1, parseInt(document.getElementById('q-skillet').innerText)-1)">-</button>
									<span id="q-skillet">1</span>
									<button onclick="document.getElementById('q-skillet').innerText = parseInt(document.getElementById('q-skillet').innerText)+1">+</button>
								</div>
								<button class="add-crate-btn" data-id="skillet" data-name="Cast Iron Skillet" data-price="180">Add to Crate</button>
							</div>
						</div>

					</div>

					<!-- MARKETS SUBSECTION INSIDE SHOP PANE (like mockup) -->
					<div class="markets-banner" id="markets">
						<div class="markets-banner-text">
							<h2>Find Us at<br/>These Markets</h2>
						</div>
						<img src="https://images.unsplash.com/photo-1596733430284-f743727546a6?auto=format&fit=crop&q=80&w=400" alt="Wooden Crates" class="markets-banner-img" />
					</div>
				</div>
			</div>
		</section>

		<!-- FOOTER -->
		<footer class="main-footer">
			<div class="footer-content">
				<h2 class="logo-text">REBEL TALLOW CO.</h2>
				<p class="footer-copy">&copy; 2026 REBEL TALLOW CO. SOUTH AFRICA 🇿🇦 <br/><br/> NO EXCUSES. JUST PURE REBELLION.</p>
			</div>
		</footer>

		<!-- CART SHIELD AND DRAWER -->
		<div class="cart-shield" id="cart-shield"></div>
		<div class="cart-panel" id="cart-panel">
			<div class="cart-top">
				<h3>YOUR CRATE</h3>
				<button id="cart-exit" class="close-cart-btn">✕</button>
			</div>
			<div id="cart-body" class="cart-body">
				<p class="cart-empty">YOUR CRATE IS EMPTY</p>
			</div>
			<div class="cart-bottom">
				<div class="cart-math"><span>TOTAL</span><span id="cart-total">R0</span></div>
				<button id="checkout-btn" class="checkout-btn" disabled>ORDER ON WHATSAPP</button>
			</div>
		</div>
	</main>
</Layout>

<script is:inline>
(function() {
	var cart = {};

	function drawCart() {
		var body = document.getElementById('cart-body');
		var tally = document.getElementById('cart-tally');
		var total = document.getElementById('cart-total');
		var waBtn = document.getElementById('checkout-btn');
		var keys = Object.keys(cart);

		if (!body) return;

		if (keys.length === 0) {
			body.innerHTML = '<p class="cart-empty">YOUR CRATE IS EMPTY</p>';
			if (tally) tally.textContent = '0';
			if (tally) tally.style.display = 'none';
			if (total) total.textContent = 'R0';
			if (waBtn) waBtn.disabled = true;
			return;
		}

		var count = 0, sum = 0;
		var html = '';
		keys.forEach(function(pid) {
			var item = cart[pid];
			count += item.qty;
			var lineTotal = item.qty * item.price;
			sum += lineTotal;
			html += '<div class="cart-row">' +
				'<div class="cart-row-top"><span>' + item.name + '</span><span class="row-price">R' + lineTotal + '</span></div>' +
				'<div class="cart-row-btns">' +
				'<button onclick="rebelCartDec(\'' + pid + '\')" class="cv-btn">-</button>' +
				'<span class="cv-val">' + item.qty + '</span>' +
				'<button onclick="rebelCartInc(\'' + pid + '\')" class="cv-btn">+</button>' +
				'</div></div>';
		});

		body.innerHTML = html;
		if (tally) { tally.textContent = count.toString(); tally.style.display = 'flex'; }
		if (total) total.textContent = 'R' + sum;
		if (waBtn) waBtn.disabled = false;
	}

	window.rebelCartInc = function(pid) { if (cart[pid]) { cart[pid].qty++; drawCart(); } };
	window.rebelCartDec = function(pid) {
		if (cart[pid]) {
			cart[pid].qty--;
			if (cart[pid].qty <= 0) delete cart[pid];
			drawCart();
		}
	};

	document.addEventListener('DOMContentLoaded', function() {
		// ADD TO CRATE
		document.querySelectorAll('.add-crate-btn').forEach(function(btn) {
			btn.addEventListener('click', function() {
				var id = btn.getAttribute('data-id');
				var name = btn.getAttribute('data-name');
				var price = parseInt(btn.getAttribute('data-price'), 10);
				var qtyEl = document.getElementById('q-' + id);
				var q = qtyEl ? parseInt(qtyEl.innerText) : 1;
				
				if (!cart[id]) cart[id] = { name: name, price: price, qty: 0 };
				cart[id].qty += q;
				
				// Feedback
				var originalText = btn.innerText;
				btn.innerText = "✓ Added";
				btn.classList.add('added');
				setTimeout(function() { 
					btn.innerText = originalText; 
					btn.classList.remove('added'); 
				}, 1500);
				
				if (qtyEl) qtyEl.innerText = '1';
				
				drawCart();
			});
		});

		// CART PANEL LOGIC
		var cartPanel = document.getElementById('cart-panel');
		var cartShield = document.getElementById('cart-shield');
		var cartOpen = document.getElementById('cart-open');
		var cartExit = document.getElementById('cart-exit');

		function openCart() {
			if (cartPanel) cartPanel.classList.add('visible');
			if (cartShield) cartShield.classList.add('visible');
		}
		function closeCart() {
			if (cartPanel) cartPanel.classList.remove('visible');
			if (cartShield) cartShield.classList.remove('visible');
		}

		if (cartOpen) cartOpen.addEventListener('click', openCart);
		if (cartExit) cartExit.addEventListener('click', closeCart);
		if (cartShield) cartShield.addEventListener('click', closeCart);

		// WHATSAPP CHECKOUT
		var waBtn = document.getElementById('checkout-btn');
		if (waBtn) waBtn.addEventListener('click', function() {
			var num = "27636936204";
			var total = 0;
			var msg = "Hi RebelCo! My Natural Rebellion crate order:\n\n";
			Object.keys(cart).forEach(function(pid) {
				var item = cart[pid];
				var lineTotal = item.qty * item.price;
				msg += '• ' + item.qty + ' x ' + item.name + ' (R' + lineTotal + ')\n';
				total += lineTotal;
			});
			msg += '\nTOTAL: R' + total + '\n\nI am ready for the pure rebellion.';
			window.open('https://wa.me/' + num + '?text=' + encodeURIComponent(msg), '_blank');
		});

		// SMOOTH SCROLL FOR NAV LINKS
		document.querySelectorAll('.desktop-nav a').forEach(anchor => {
			anchor.addEventListener('click', function (e) {
				e.preventDefault();
				document.querySelector(this.getAttribute('href')).scrollIntoView({
					behavior: 'smooth'
				});
			});
		});

		// PREVENT SCROLL RESTORATION ISSUES
		if ('scrollRestoration' in history) {
			history.scrollRestoration = 'manual';
		}
	});

})();
</script>

<style>
	/* Use strong, bold sans-serifs for headers to match mockups, and a readable serif/sans for body */
	@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

	:root { 
		--gold-light: #e6c589;
		--gold-mid: #c09d5a;
		--gold-dark: #8c6e31;
		--black:#060606;
		--dark-grey: #121212;
		--wood-dark: #0f0a05;
		--text-light: #e5e5e5;
	}
	* { box-sizing: border-box; }
	html, body {
		margin: 0; padding: 0; background: var(--black); color: var(--text-light);
		font-family: 'Libre Baskerville', serif; overflow-x: hidden;
	}

	/* ── FILM GRAIN & ATMOSPHERE ─────────────────────── */
	.film-grain {
		position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
		pointer-events: none; z-index: 9999;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.35'/%3E%3C/svg%3E");
		opacity: 0.12;
		mix-blend-mode: overlay;
	}

	/* ── UTILS ───────────────────────────────────────── */
	.logo-text { font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--gold-light); }
	.logo-text-large { font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--gold-light); font-size: 4rem; text-shadow: 2px 2px 10px rgba(0,0,0,0.8); }
	.logo-text-huge { font-family: 'Bebas Neue', sans-serif; letter-spacing: 3px; color: var(--gold-light); font-size: clamp(4rem, 10vw, 8rem); margin: 0; line-height: 1; text-shadow: 2px 2px 20px rgba(0,0,0,0.9); text-align: center;}

	/* ── HEADER ──────────────────────────────────────── */
	.main-header {
		position: absolute; top: 0; left: 0; right: 0; z-index: 1000;
		padding: 1.5rem 2rem; 
		background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
	}
	.header-inner { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; max-width: 1600px; margin: 0 auto; }
	.header-left { display: flex; align-items: center; justify-content: flex-start; }
	.skull-logo-link { display: flex; align-items: center; text-decoration: none; }
	.skull-logo { width: 50px; height: 50px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.8)); }
	.header-center { display: flex; justify-content: center; }
	.header-center .logo-text { font-size: 2.2rem; text-decoration: none; margin-top: 5px; }
	
	.header-right { display: flex; align-items: center; justify-content: flex-end; gap: 2rem; }
	.desktop-nav { display: flex; gap: 2rem; }
	.desktop-nav a {
		font-family: 'Bebas Neue', sans-serif; color: var(--gold-light); text-decoration: none;
		font-size: 1.3rem; letter-spacing: 1.5px; transition: color 0.3s;
		text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
	}
	.desktop-nav a:hover { color: #fff; }
	
	.cart-btn {
		background: transparent; border: none; color: var(--gold-light); cursor: pointer;
		display: flex; align-items: center; position: relative; padding: 0; outline: none;
	}
	.cart-icon { width: 28px; height: 28px; filter: drop-shadow(1px 1px 2px #000); }
	.tally-badge {
		position: absolute; top: -5px; right: -10px; background: #fff; color: #000;
		font-size: 0.8rem; font-family: sans-serif; font-weight: bold;
		border-radius: 50%; width: 18px; height: 18px; display: none; align-items: center; justify-content: center;
	}

	/* ── HERO SECTION ────────────────────────────────── */
	.hero-section {
		height: 100vh; position: relative; display: flex; align-items: center; justify-content: center;
		overflow: hidden;
	}
	.hero-bg {
		position: absolute; inset: 0;
		/* Use a smokey background */
		background: url('https://images.unsplash.com/photo-1542382257-80ddbfc7478d?auto=format&fit=crop&q=80&w=2000') center/cover;
		filter: contrast(1.1) brightness(0.4) saturate(0.8);
	}
	.smoke-overlay {
		position: absolute; inset: 0;
		background: radial-gradient(circle at center, rgba(0,0,0,0) 0%, rgba(0,0,0,0.8) 100%);
	}
	.hero-content { position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center; padding: 0 2rem; width: 100%;}
	
	.hero-skull-wrapper { position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%); z-index: -1; width: 80%; max-width: 1200px; opacity: 0.5; mix-blend-mode: screen;}
	.hero-skull-img { width: 100%; height: auto; object-fit: contain; filter: contrast(1.5) brightness(1.2) drop-shadow(0 0 50px #000); }

	.hero-slogan {
		font-family: 'Playfair Display', serif; color: var(--text-light);
		font-size: clamp(1.2rem, 3vw, 2.2rem); margin: 1rem 0 3rem 0; text-shadow: 2px 2px 10px #000;
		text-align: center; font-style: italic; line-height: 1.4; font-weight: 400;
	}
	
	.hero-actions { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
	.gold-btn {
		font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 2px;
		padding: 0.8rem 3rem; text-decoration: none; cursor: pointer; transition: all 0.3s;
		text-align: center; border-radius: 2px;
	}
	.gold-btn.btn-solid {
		background: linear-gradient(to bottom, #f3d79b 0%, #c19b51 100%);
		color: #000; border: none; box-shadow: 0 4px 15px rgba(0,0,0,0.6);
	}
	.gold-btn.btn-solid:hover { background: linear-gradient(to bottom, #fff 0%, #dcc287 100%); }
	
	.gold-btn.btn-outline {
		background: transparent; color: var(--gold-light);
		border: 2px solid var(--gold-mid); backdrop-filter: blur(5px);
	}
	.gold-btn.btn-outline:hover { background: rgba(193, 155, 81, 0.1); }

	/* ── SPLIT SECTION (Mockup layout) ───────────────── */
	.split-section { display: flex; width: 100vw; min-height: 100vh; background: var(--black); }
	
	.split-left {
		width: 40%; padding: 4rem; display: flex; flex-direction: column; align-items: center;
		border-right: 1px solid #222; position: relative; overflow: hidden;
	}
	.rebellion-content { position: sticky; top: 4rem; display: flex; flex-direction: column; align-items: center; text-align: center; }
	.rebellion-sub { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: #888; letter-spacing: 1px; margin-top: -1rem; margin-bottom: 3rem; }
	.rebellion-skull { width: 100%; max-width: 400px; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.9)) contrast(1.2); }

	.split-right {
		width: 60%; position: relative; padding: 4rem; background: #0f0f0f;
	}
	.shop-wood-bg {
		position: absolute; inset: 0;
		background: url('https://images.unsplash.com/photo-1581417478175-a9ef18abedbb?auto=format&fit=crop&q=80&w=1920') center/cover;
		opacity: 0.2; pointer-events: none; mix-blend-mode: multiply;
	}
	.shop-content { position: relative; z-index: 10; padding-bottom: 4rem; }
	
	.shop-grid {
		display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 2rem; margin-top: 2rem;
	}
	
	.product-card {
		background: rgba(15, 15, 15, 0.6); backdrop-filter: blur(10px);
		border: 1px solid rgba(255,255,255,0.05); padding: 1.5rem;
		display: flex; flex-direction: column; align-items: center; position: relative;
		transition: transform 0.3s;
	}
	.product-card:hover { transform: translateY(-5px); border-color: rgba(192, 157, 90, 0.3); }
	
	.rebel-stamp {
		position: absolute; top: 1rem; right: 1rem; width: 40px; height: 40px;
		background: var(--gold-mid); color: #000; font-family: 'Playfair Display', serif; font-style: italic; font-weight: bold; font-size: 0.8rem;
		display: flex; align-items: center; justify-content: center; border-radius: 50%;
		transform: rotate(15deg); box-shadow: 2px 2px 5px rgba(0,0,0,0.5); z-index: 5;
	}
	
	.card-img-wrap { width: 100%; aspect-ratio: 4/5; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; overflow: hidden;}
	.card-img-wrap img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.9) contrast(1.1); box-shadow: 0 10px 20px rgba(0,0,0,0.5); transition: 0.3s; }
