---
import Layout from '../layouts/Layout.astro';
import biomes from '../data/biomes.json';
const pageTitle = "REBEL | Handcrafted Tallow Soap";
---

<Layout title={pageTitle}>
	<main class="rebel-layout" id="main-content">
		<!-- Benefits Left -->
		<section class="panel panel-grey biome-panel-left">
			<div class="content" id="benefits-left"></div>
		</section>

		<!-- Ingredients Left -->
		<section class="panel panel-black ingredients-left">
			<div class="ingredient-block">
				<div class="image-placeholder ingredient-img-left" id="img-left"></div>
				<h2 class="accent-text">INGREDIENTS</h2>
				<div id="ingredients-list-left"></div>
			</div>
			<div class="texture-overlay texture-top" id="texture-top"></div>
		</section>

		<!-- Official REBEL Logo Section -->
		<section class="panel panel-logo">
			<div class="logo-wrapper">
				<div class="official-logo-container">
					<div class="rebel-header">
						<span class="rebel-brand">REBEL</span>
					</div>
					<div class="skull-container" id="skull-svg-container">
						<svg viewBox="0 0 200 200" class="bull-skull-svg" id="bull-skull">
							<path fill="currentColor" d="M100 40c-15 0-30 5-30 15s10 20 10 20l5 15s-15 5-15 15c0 10 15 15 15 15l5 25 10 15 10-15 5-25s15-5 15-15c0-10-15-15-15-15l5-15s10-10 10-20-15-15-30-15zm-25 10c10 0 20 5 20 10s-5 10-10 10-15-5-15-10 5-10 5-10zm50 0c0 0-5 5-5 10s5 10 15 10 10-5 10-10-10-10-20-10z" />
							<path fill="currentColor" d="M100 160l-15-20-5-30c-10-5-15-15-15-25 0-15 15-20 15-20l10-25c0-10-15-15-30-15s-30 5-30 20c0 10 10 15 15 15l10 20s-15 5-15 15c0 15 15 20 15 20l5 20 20 25zm0 0l15-20 5-30c10-5 15-15 15-25 0-15-15-20-15-20l-10-25c0-10 15-15 30-15s30 5 30 20c0 10-10 15-15 15l-10 20s15 5 15 15c0 15-15 20-15 20l-5 20-20 25z" />
						</svg>
					</div>
					<div class="tallow-soap-footer">
						<div class="line"></div>
						<div class="footer-text">TALLOW SOAP</div>
						<div class="line"></div>
					</div>
					<div class="disruption-text">Handcrafted Disruption</div>
				</div>
				<div class="logo-footer accent-text" id="biome-label">
					CHARCOAL AND TURMERIC
				</div>

				<!-- Quote Generator UI -->
				<div class="quote-generator">
					<div class="qty-controls">
						<button class="qty-btn" id="qty-minus">-</button>
						<span class="qty-display" id="qty-count">1</span>
						<button class="qty-btn" id="qty-plus">+</button>
					</div>
					<button class="order-btn" id="add-to-order">ADD TO ORDER</button>
				</div>
			</div>
		</section>

		<!-- Ingredients Right -->
		<section class="panel panel-black ingredients-right">
			<div class="ingredient-block">
				<div class="image-placeholder ingredient-img-right" id="img-right"></div>
				<h2 class="accent-text">INGREDIENTS</h2>
				<div id="ingredients-list-right"></div>
			</div>
			<div class="texture-overlay texture-bottom" id="texture-bottom"></div>
		</section>

		<!-- Benefits Right -->
		<section class="panel panel-grey biome-panel-right">
			<div class="content" id="benefits-right"></div>
		</section>

		<!-- Cart Summary Panel -->
		<div class="cart-summary" id="cart-summary">
			<div class="cart-header">YOUR ORDER</div>
			<div class="cart-items" id="cart-items">
				<p class="empty-msg">No items added yet.</p>
			</div>
			<button class="whatsapp-btn" id="whatsapp-order" disabled>
				SEND ORDER VIA WHATSAPP
			</button>
		</div>

		<!-- Biome Selector -->
		<nav class="biome-selector">
			{biomes.map((biome) => (
				<button 
					class="biome-btn" 
					data-id={biome.id} 
					title={biome.name}
					style={`--btn-color: ${biome.accent}`}
				></button>
			))}
		</nav>
	</main>
</Layout>

<script define:vars={{ biomes }}>
	const body = document.body;
	const buttons = document.querySelectorAll('.biome-btn');
	
	const benefitsLeft = document.getElementById('benefits-left');
	const benefitsRight = document.getElementById('benefits-right');
	const ingredientsLeft = document.getElementById('ingredients-list-left');
	const ingredientsRight = document.getElementById('ingredients-list-right');
	const biomeLabel = document.getElementById('biome-label');
	const imgLeft = document.getElementById('img-left');
	const imgRight = document.getElementById('img-right');
	const bullSkull = document.getElementById('bull-skull');

	// Cart & Qty Logic
	let currentBiomeId = biomes[0].id;
	let currentQty = 1;
	let cart = {}; // { biomeId: { name: string, qty: number } }

	const qtyDisplay = document.getElementById('qty-count');
	const qtyMinus = document.getElementById('qty-minus');
	const qtyPlus = document.getElementById('qty-plus');
	const addToOrder = document.getElementById('add-to-order');
	const cartItems = document.getElementById('cart-items');
	const whatsappOrder = document.getElementById('whatsapp-order');

	function updateQty(val) {
		currentQty = Math.max(1, currentQty + val);
		qtyDisplay.innerText = currentQty;
	}

	function updateCartUI() {
		const items = Object.entries(cart);
		if (items.length === 0) {
			cartItems.innerHTML = '<p class="empty-msg">No items added yet.</p>';
			whatsappOrder.disabled = true;
			return;
		}

		cartItems.innerHTML = items.map(([id, item]) => `
			<div class="cart-item">
				<span>${item.qty} x ${item.name}</span>
				<button class="remove-btn" onclick="document.dispatchEvent(new CustomEvent('remove-from-cart', { detail: '${id}' }))">×</button>
			</div>
		`).join('');
		whatsappOrder.disabled = false;
	}

	qtyMinus.addEventListener('click', () => updateQty(-1));
	qtyPlus.addEventListener('click', () => updateQty(1));

	addToOrder.addEventListener('click', () => {
		const biome = biomes.find(b => b.id === currentBiomeId);
		if (!cart[currentBiomeId]) {
			cart[currentBiomeId] = { name: biome.name, qty: 0 };
		}
		cart[currentBiomeId].qty += currentQty;
		currentQty = 1;
		qtyDisplay.innerText = currentQty;
		updateCartUI();
	});

	whatsappOrder.addEventListener('click', () => {
		const number = "27636936204";
		let message = "Hi RebelCo! I'd like to request a quote for:\n\n";
		Object.values(cart).forEach(item => {
			message += `• ${item.qty} x ${item.name}\n`;
		});
		message += "\nPlease let me know the total and delivery details.";
		
		const url = `https://wa.me/${number}?text=${encodeURIComponent(message)}`;
		window.open(url, '_blank');
	});

	document.addEventListener('remove-from-cart', (e) => {
		delete cart[e.detail];
		updateCartUI();
	});

	function switchBiome(id) {
		currentBiomeId = id;
		const data = biomes.find(b => b.id === id);
		if (!data) return;

		document.querySelectorAll('.panel .content, .ingredient-block, .logo-wrapper').forEach(el => {
			el.style.opacity = '0';
			el.style.transform = 'translateY(10px)';
		});

		setTimeout(() => {
			body.setAttribute('data-biome', id);

			benefitsLeft.innerHTML = data.benefitsLeft.map(b => `<p>• ${b}</p>`).join('');
			benefitsRight.innerHTML = data.benefitsRight.map(b => `<p>• ${b}</p>`).join('');
			ingredientsLeft.innerHTML = data.ingredientsLeft.map(i => `<p>${i.toUpperCase()},</p>`).join('');
			ingredientsRight.innerHTML = data.ingredientsRight.map(i => `<p>${i.toUpperCase()},</p>`).join('');
			biomeLabel.innerText = data.name.toUpperCase();
			
			imgLeft.style.backgroundImage = `url(${data.images.left})`;
			imgRight.style.backgroundImage = `url(${data.images.right})`;
			
			bullSkull.style.color = data.accent;

			document.querySelectorAll('.panel .content, .ingredient-block, .logo-wrapper').forEach(el => {
				el.style.transition = 'all 0.8s ease-out';
				el.style.opacity = '1';
				el.style.transform = 'translateY(0)';
			});
		}, 400);
	}

	buttons.forEach(btn => {
		btn.addEventListener('click', () => {
			buttons.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			switchBiome(btn.dataset.id);
		});
	});

	buttons[0].click();
</script>

<style>
	.rebel-layout {
		display: grid;
		grid-template-columns: 1fr 1fr 1.5fr 1fr 1fr;
		height: 100vh;
		width: 100vw;
		overflow: hidden;
		background: var(--main-bg);
		transition: background-color 1.2s ease;
	}

	.panel {
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: center;
		border-right: 1px solid rgba(255, 255, 255, 0.1);
	}

	.panel-grey {
		background: var(--panel-bg);
		color: var(--panel-text);
		padding: 2.5rem;
		text-align: left;
	}

	.panel-grey :global(p) {
		font-family: 'Staatliches', cursive;
		font-size: 1.15rem;
		line-height: 1.4;
		margin-bottom: 2rem;
		text-transform: uppercase;
		opacity: 0.95;
	}

	.panel-black {
		background: var(--main-bg);
		padding: 1rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.official-logo-container {
		width: 400px;
		height: 400px;
		background: #f1ebd8;
		border-radius: 50%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		position: relative;
		box-shadow: inset 0 0 100px rgba(0,0,0,0.1), 0 20px 50px rgba(0,0,0,0.5);
		margin-bottom: 1.5rem;
		color: #1a1a1a;
		border: 8px solid rgba(0,0,0,0.05);
		mask-image: radial-gradient(circle, white 90%, transparent 100%);
	}

	.rebel-brand {
		font-family: 'Staatliches', cursive;
		font-size: 5.5rem;
		color: #ef4444;
		letter-spacing: -0.02em;
		line-height: 1;
		margin-bottom: -1rem;
	}

	.skull-container {
		width: 220px;
		height: 220px;
		margin: -1rem 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.bull-skull-svg {
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 5px 15px rgba(0,0,0,0.2));
		transition: color 1s ease;
	}

	.tallow-soap-footer {
		display: flex;
		align-items: center;
		gap: 1rem;
		width: 80%;
		margin-top: -1rem;
	}

	.tallow-soap-footer .line {
		height: 2px;
		flex-grow: 1;
		background: #1a1a1a;
	}

	.footer-text {
		font-family: 'Staatliches', cursive;
		font-size: 2rem;
		letter-spacing: 0.1em;
	}

	.disruption-text {
		position: absolute;
		bottom: 20px;
		right: 35px;
		font-family: 'Inter', sans-serif;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: rgba(0,0,0,0.4);
		transform: rotate(-15deg);
	}

	.logo-footer {
		font-family: 'Bangers', cursive;
		font-size: 2.2rem;
		letter-spacing: 0.05em;
		text-shadow: 2px 2px 0px rgba(0,0,0,1);
		margin-bottom: 1.5rem;
	}

	/* Quote UI */
	.quote-generator {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		z-index: 20;
	}

	.qty-controls {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		background: rgba(255,255,255,0.1);
		padding: 0.4rem 1.2rem;
		border-radius: 999px;
		border: 1px solid rgba(255,255,255,0.2);
	}

	.qty-btn {
		background: none;
		border: none;
		color: white;
		font-size: 1.8rem;
		font-family: 'Staatliches', cursive;
		padding: 0;
		line-height: 1;
	}

	.qty-display {
		font-family: 'Staatliches', cursive;
		font-size: 1.8rem;
		min-width: 1.5rem;
		text-align: center;
	}

	.order-btn {
		background: #ef4444;
		color: white;
		border: none;
		font-family: 'Staatliches', cursive;
		font-size: 1.4rem;
		padding: 0.6rem 2.5rem;
		border-radius: 4px;
		letter-spacing: 0.05em;
		transition: all 0.3s ease;
		box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
	}

	.order-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(239, 68, 68, 0.6);
	}

	/* Cart Sidebar/Summary */
	.cart-summary {
		position: fixed;
		top: 2rem;
		right: 2rem;
		width: 300px;
		background: rgba(0,0,0,0.9);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 8px;
		padding: 1.5rem;
		z-index: 100;
		backdrop-filter: blur(10px);
		box-shadow: 0 10px 40px rgba(0,0,0,0.5);
	}

	.cart-header {
		font-family: 'Staatliches', cursive;
		font-size: 1.6rem;
		color: #ef4444;
		border-bottom: 1px solid rgba(255,255,255,0.1);
		padding-bottom: 0.5rem;
		margin-bottom: 1rem;
		letter-spacing: 0.05em;
	}

	.cart-items {
		max-height: 200px;
		overflow-y: auto;
		margin-bottom: 1.5rem;
	}

	.cart-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: 'Staatliches', cursive;
		font-size: 1.1rem;
		padding: 0.4rem 0;
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}

	.remove-btn {
		background: none;
		border: none;
		color: rgba(255,255,255,0.4);
		font-size: 1.2rem;
		cursor: pointer;
	}

	.remove-btn:hover { color: #ef4444; }

	.empty-msg {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		color: rgba(255,255,255,0.4);
		text-align: center;
	}

	.whatsapp-btn {
		width: 100%;
		background: #25d366;
		color: white;
		border: none;
		padding: 0.8rem;
		border-radius: 4px;
		font-family: 'Staatliches', cursive;
		font-size: 1.2rem;
		letter-spacing: 0.05em;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		transition: all 0.3s ease;
	}

	.whatsapp-btn:disabled {
		background: #2a2a2a;
		opacity: 0.5;
		cursor: not-allowed;
	}

	.whatsapp-btn:not(:disabled):hover {
		background: #128c7e;
		transform: scale(1.02);
	}

	/* Biome Selector */
	.biome-selector {
		position: fixed;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 1.2rem;
		background: rgba(0,0,0,0.85);
		padding: 1rem;
		border-radius: 999px;
		z-index: 1000;
		backdrop-filter: blur(15px);
		border: 1px solid rgba(255,255,255,0.1);
	}

	.biome-btn {
		width: 28px;
		height: 28px;
		border-radius: 50%;
		border: 3px solid transparent;
		background: var(--btn-color);
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.biome-btn.active {
		border-color: white;
		transform: scale(1.4);
		box-shadow: 0 0 20px var(--btn-color);
	}

	.image-placeholder {
		width: 100%;
		background-size: cover;
		background-position: center;
		transition: background-image 1s ease;
		filter: grayscale(0.5) contrast(1.2);
	}

	.ingredient-img-left, .ingredient-img-right {
		height: 200px;
		margin-bottom: 1.5rem;
	}

	@media (max-width: 1024px) {
		.rebel-layout { grid-template-columns: 1fr; height: auto; overflow-y: auto; }
		.panel { min-height: 450px; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
		.official-logo-container { width: 320px; height: 320px; }
		.rebel-brand { font-size: 4rem; }
		.footer-text { font-size: 1.5rem; }
		.cart-summary { position: relative; top: 0; right: 0; width: 100%; box-shadow: none; border-radius: 0; background: #000; }
	}
</style>
