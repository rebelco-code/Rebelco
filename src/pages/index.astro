---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL | Choose Your Disruption">
	<main class="gateway-container">
		<!-- Section selection split -->
		<div class="gateway-split">
			<!-- Soap Side -->
			<a href="/soap" class="gateway-side soap-side">
				<div class="gateway-bg" style="background-image: url('https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&q=80&w=1920');"></div>
				<div class="gateway-content">
					<div class="side-label">CINEMATIC SKINCARE</div>
					<h2 class="side-title">THE SOAP<br/>DISRUPTION</h2>
					<div class="explore-btn">ENTER BIOMES</div>
				</div>
			</a>

			<!-- Laser Side -->
			<a href="/gifts" class="gateway-side laser-side">
				<div class="gateway-bg" style="background-image: url('https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&q=80&w=1920');"></div>
				<div class="gateway-content">
					<div class="side-label">INDUSTRIAL PRECISION</div>
					<h2 class="side-title">THE LASER<br/>WORKSHOP</h2>
					<div class="explore-btn">EXPLORE GIFTS</div>
				</div>
			</a>
		</div>

		<!-- Central Logo Overlay -->
		<div class="central-branding">
			<img src="/logo.png" alt="REBEL Logo" class="center-logo" />
			<div class="mission-text">
				<p>FAMILY OWNED. ALL NATURAL. CAREFULLY HANDCRAFTED.</p>
				<p>REBEL AGAINST THE NORM.</p>
			</div>
		</div>

        <!-- Background Video/Ambient Overlay for "Beautiful Backgrounds" -->
        <div class="ambient-glow"></div>
	</main>
</Layout>

<style>
	:root {
		--gold: #f59e0b;
		--dark: #000;
	}

	.gateway-container {
		height: 100vh;
		width: 100vw;
		overflow: hidden;
		position: relative;
		background: #000;
	}

	.gateway-split {
		display: flex;
		height: 100%;
		width: 100%;
	}

	.gateway-side {
		flex: 1;
		position: relative;
		overflow: hidden;
		text-decoration: none;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: flex 0.8s cubic-bezier(0.23, 1, 0.32, 1);
        cursor: pointer;
	}

	.gateway-side:hover {
		flex: 1.5;
	}

	.gateway-bg {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		filter: brightness(0.5) grayscale(0.2);
		transition: filter 0.8s, transform 0.8s, scale 0.8s;
		z-index: 1;
	}

	.gateway-side:hover .gateway-bg {
		filter: brightness(0.7) grayscale(0);
		transform: scale(1.1);
	}

	.gateway-content {
		position: relative;
		z-index: 10;
		text-align: center;
		color: #fff;
		pointer-events: none;
        transition: transform 0.6s;
	}

    .gateway-side:hover .gateway-content {
        transform: scale(1.1);
    }

	.side-label {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		letter-spacing: 0.6rem;
		margin-bottom: 1.5rem;
		color: var(--gold);
		opacity: 0.9;
        font-weight: bold;
	}

	.side-title {
		font-family: 'Bangers', cursive;
		font-size: clamp(3rem, 6vw, 6rem);
		line-height: 0.85;
		margin: 0;
		text-shadow: 0 10px 40px rgba(0,0,0,1);
	}

	.explore-btn {
		margin-top: 2.5rem;
		display: inline-block;
		padding: 1.2rem 3rem;
		border: 2px solid #fff;
		font-family: 'Staatliches', cursive;
		font-size: 1.5rem;
		letter-spacing: 0.2rem;
		transition: all 0.4s;
        border-radius: 4px;
	}

	.gateway-side:hover .explore-btn {
		background: #fff;
		color: #000;
        box-shadow: 0 0 30px rgba(255,255,255,0.4);
	}

	/* Central Overlay */
	.central-branding {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 20;
		text-align: center;
		pointer-events: none;
        transition: opacity 0.4s;
	}

    .gateway-side:hover ~ .central-branding {
        opacity: 0.2;
    }

	.center-logo {
		width: clamp(140px, 20vw, 220px);
		height: auto;
		filter: drop-shadow(0 0 50px rgba(0,0,0,1));
		margin-bottom: 2.5rem;
	}

	.mission-text {
		font-family: 'Staatliches', cursive;
		color: #fff;
		font-size: 1.3rem;
		opacity: 1;
		letter-spacing: 0.15rem;
        text-shadow: 0 4px 10px rgba(0,0,0,0.8);
	}

	.mission-text p { margin: 0.8rem 0; }

    .ambient-glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.6) 100%);
        pointer-events: none;
        z-index: 5;
    }

	/* Separator Line */
	.gateway-side::after {
		content: '';
		position: absolute;
		right: 0;
		top: 0;
		bottom: 0;
		width: 1px;
		background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.3), transparent);
		z-index: 15;
	}
	.laser-side::after { display: none; }

	@media (max-width: 768px) {
		.gateway-split { flex-direction: column; }
		.gateway-side:hover { flex: 1.2; }
		.central-branding { top: 50%; width: 100%; transform: translate(-50%, -50%) scale(0.8); }
		.center-logo { width: 140px; }
		.side-title { font-size: 3.5rem; }
		.gateway-side::after {
			right: 0;
			left: 0;
			bottom: 0;
			top: auto;
			width: auto;
			height: 1px;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.3), transparent);
		}
	}
</style>
