							<div class="rebel-stamp">Rebel</div>
							<div class="card-img-wrap">
								<img src="/canva_slide_11.png" alt="Himalayan Salt Soap" class="label-photo"/>
							</div>
							<div class="card-bottom">
								<h3 class="prod-title">Himalayan Salt</h3>
								<p class="price">R100</p>
								<div class="qty-control">
									<button onclick="document.getElementById('q-salt').innerText = Math.max(1, parseInt(document.getElementById('q-salt').innerText)-1)">-</button>
									<span id="q-salt">1</span>
									<button onclick="document.getElementById('q-salt').innerText = parseInt(document.getElementById('q-salt').innerText)+1">+</button>
								</div>
								<div class="action-buttons">
									<button class="add-crate-btn" data-id="salt" data-name="Himalayan Salt Soap" data-price="100">Add to Crate</button>
