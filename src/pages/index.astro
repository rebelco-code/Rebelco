---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL | Handcrafted Tallow Soap">
	<main class="scroll-container">
		<!-- Header / Logo -->
		<header class="sticky-header" id="main-header">
			<img src="/logo.png" alt="REBEL Logo" class="sticky-logo" />
		</header>
		
		<!-- Section 0: Landing Page -->
		<section class="page-section landing-page" id="home">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="center-panel landing-content">
				<img src="/logo.png" alt="REBEL Tallow Soap" class="hero-logo" />
				<h1 class="landing-tagline">HANDCRAFTED DISRUPTION</h1>
				<div class="about-rebel-box">
					<p>REBEL is family owned, all natural, soap and skin care product manufacturer.</p>
					<p>We 'rebel' against harsh chemicals in our carefully-handcrafted disruption against the norm of modern skincare.</p>
					<p>Rebel uses old techniques with a modern approach for every age!</p>
				</div>
				<div class="scroll-indicator">
					<span>SCROLL TO DISRUPT</span>
					<div class="arrow"></div>
				</div>
			</div>
		</section>

		<!-- Product Biome Sections -->
		{[
			{
				id: 'charcoal',
				name: 'Charcoal & Turmeric',
				hero: '/charcoal_turmeric_hero.png',
				bg: 'https://images.unsplash.com/photo-1547234935-80c7145ec969?auto=format&fit=crop&q=80&w=1920',
				bullets: [
					'CHARCOAL ACTS LIKE A MAGNET, DRAWING OUT IMPURITIES.',
					'GENTLE PHYSICAL EXFOLIATION FOR SMOOTHER TEXTURE.',
					'TURMERIC REDUCES REDNESS AND BREAKOUTS.',
					'ANTIOXIDANTS BRIGHTEN SKIN OVER TIME.'
				],
				ingredients: 'NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, CHARCOAL, TURMERIC',
				extra: [
					'• DETOXIFIES PORES WITHOUT STRIPPING OILS.',
					'• PROMOTES A RADIANT, EVEN SKIN TONE.'
				]
			},
			{
				id: 'rooibos',
				name: 'Rooibos & Tea Tree',
				hero: '/rooibos_hero.png',
				bg: 'https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&q=80&w=1920',
				bullets: [
					'RICH IN ANTIOXIDANTS FOR CELLULAR REPAIR.',
					'GENTLE EXFOLIATION PROMOTING RADIANT SKIN.',
					'ANTI-INFLAMMATORY HELPS SOOTHE ECZEMA.',
					'NATURALLY HYDRATING BARRIER PROTECTION.'
				],
				ingredients: 'NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, ROOIBOS, TEA TREE',
				extra: [
					'• CAFFEINE IN TEA TREE REDUCES PUFFINESS.',
					'• ANTISEPTIC PROPERTIES TO PREVENT BREAKOUTS.'
				]
			},
			{
				id: 'cocoa',
				name: 'Cocoa Coconut',
				hero: '/cocoa_hero.png',
				bg: 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&q=80&w=1920',
				bullets: [
					'COCONUT OIL DEEPLY MOISTURIZES SKIN.',
					'ANTIBACTERIAL PROPERTIES FIGHT ACNE.',
					'CACAO PACKED WITH ANTIOXIDANTS FOR GLOW.',
					'IMPROVES ELASTICITY AND MICRO-CIRCULATION.'
				],
				ingredients: 'NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, COCOA, COCONUT',
				extra: [
					'• INTENSE HYDRATION FOR DRY SKIN.',
					'• PROMOTES A YOUTHFUL, FIRM APPEARANCE.'
				]
			},
			{
				id: 'rainforest',
				name: 'Rainforest Herbs',
				hero: '/rainforest_hero.png',
				bg: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&q=80&w=1920',
				bullets: [
					'TALLOW IS BIO-IDENTICAL TO SEBUM.',
					'RICH IN VITAMINS A, D, E, AND K.',
					'MIXED HERBS PROVIDE BOTANICAL ANTIOXIDANTS.',
					'NATURAL CLEANSING WITHOUT STRIPPING OILS.'
				],
				ingredients: 'NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, MIXED HERBS',
				extra: [
					'• SOOTHES SENSITIVE SKIN WITH EXTRACTS.',
					'• RESTORES NATURAL VITALITY AND BALANCE.'
				]
			}
		].map((p) => (
			<section class={`page-section product-biome ${p.id}-biome`} id={p.id}>
				<div class="nature-bg" style={`background-image: url('${p.bg}');`}></div>
				<div class="split-layout">
					<div class="center-panel mobile-first">
						<div class="hero-image-container">
							<img src={p.hero} alt={`REBEL ${p.name}`} class="hero-img" />
						</div>
						<div class="product-info-mobile">
							<h2 class="mobile-title">{p.name}</h2>
							<p class="price-tag">R100</p>
						</div>
						<div class="order-controls gold-standard">
							<div class="qty-selector">
								<button class="qty-btn minus" data-id={p.id}>-</button>
								<span class="qty-value" id={`qty-${p.id}`}>1</span>
								<button class="qty-btn plus" data-id={p.id}>+</button>
							</div>
							<button class="add-btn premium" data-product={p.name} data-id={p.id} data-price="100">
								<span>ADD TO ORDER</span>
								<div class="success-check">✓</div>
							</button>
						</div>
						<button class="ingredients-toggle" data-id={p.id}>SEE INGREDIENTS</button>
					</div>

					<div class="text-panel left desktop-only">
						<div class="content-box">
							{p.bullets.map(b => (
								<p class="bullet">{b}</p>
							))}
						</div>
					</div>

					<div class="text-panel right ingredients-panel" id={`ingredients-${p.id}`}>
						<button class="close-panel" data-id={p.id}>×</button>
						<div class="ingredients-box">
							<h3 class="accent-text">INGREDIENTS</h3>
							<p>{p.ingredients}</p>
							<div class="extra-benefits">
								{p.extra.map(e => (
									<p>{e}</p>
								))}
							</div>
						</div>
					</div>
				</div>
			</section>
		))}

		<!-- Gold Standard Cart -->
		<button id="cart-toggle" class="cart-trigger">
			<span class="cart-count">0</span>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4H6zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
		</button>

		<div class="cart-overlay" id="cart-overlay"></div>
		<div class="cart-sidebar" id="cart-sidebar">
			<div class="cart-header-gold">
				<h3>YOUR REBEL ORDER</h3>
				<button id="cart-close">CLOSE</button>
			</div>
			<div id="cart-items-container" class="cart-items-scroll">
				<p class="empty-msg">YOUR CRATE IS EMPTY</p>
			</div>
			<div class="cart-footer">
				<div class="cart-total">
					<span>TOTAL:</span>
					<span id="cart-total-value">R0</span>
				</div>
				<button id="whatsapp-link" class="wa-btn-premium" disabled>
					DISRUPT THE MARKET (ORDER VIA WHATSAPP)
				</button>
			</div>
		</div>

		<!-- Nav Navigation -->
		<nav class="scroll-nav">
			<a href="#home" class="nav-dot active" title="Home"></a>
			<a href="#charcoal" class="nav-dot" title="Charcoal"></a>
			<a href="#rooibos" class="nav-dot" title="Rooibos"></a>
			<a href="#cocoa" class="nav-dot" title="Cocoa"></a>
			<a href="#rainforest" class="nav-dot" title="Rainforest"></a>
		</nav>
	</main>
</Layout>

<script>
	let cart = {};
	const itemQuantities = {
		charcoal: 1,
		rooibos: 1,
		cocoa: 1,
		rainforest: 1
	};

	const cartSidebar = document.getElementById('cart-sidebar');
	const cartOverlay = document.getElementById('cart-overlay');
	const cartToggle = document.getElementById('cart-toggle');
	const cartClose = document.getElementById('cart-close');
	const cartCount = document.querySelector('.cart-count');
	const cartList = document.getElementById('cart-items-container');
	const cartTotal = document.getElementById('cart-total-value');
	const waBtn = document.getElementById('whatsapp-link');
	
	const header = document.getElementById('main-header');
	const scrollContainer = document.querySelector('.scroll-container');

	// Gold Standard UI Handlers
	function updateCartUI() {
		const items = Object.entries(cart);
		let count = 0;
		let total = 0;

		if (items.length === 0) {
			cartList.innerHTML = '<p class="empty-msg">YOUR CRATE IS EMPTY</p>';
			cartCount.textContent = '0';
			cartTotal.textContent = 'R0';
			waBtn.disabled = true;
			return;
		}

		cartList.innerHTML = items.map(([name, item]: [string, any]) => {
			count += item.qty;
			total += item.qty * 100;
			return `
				<div class="cart-item-gold">
					<div class="item-info">
						<span class="item-name">${name}</span>
						<span class="item-price">R${item.qty * 100}</span>
					</div>
					<div class="item-controls">
						<button class="cart-qty-btn" data-product="${name}" data-action="dec">-</button>
						<span class="cart-qty-val">${item.qty}</span>
						<button class="cart-qty-btn" data-product="${name}" data-action="inc">+</button>
					</div>
				</div>
			`;
		}).join('');

		cartCount.textContent = count.toString();
		cartTotal.textContent = `R${total}`;
		waBtn.disabled = false;

		// Re-bind listeners
		document.querySelectorAll('.cart-qty-btn').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const product = (e.currentTarget as HTMLElement).dataset.product;
				const action = (e.currentTarget as HTMLElement).dataset.action;
				if (product) {
					if (action === 'inc') cart[product].qty++;
					else {
						cart[product].qty--;
						if (cart[product].qty <= 0) delete cart[product];
					}
					updateCartUI();
				}
			});
		});
	}

	// Quantity Selectors Logic
	document.querySelectorAll('.qty-btn').forEach(btn => {
		btn.addEventListener('click', (e) => {
			const bid = (e.currentTarget as HTMLElement).dataset.id;
			const isPlus = (e.currentTarget as HTMLElement).classList.contains('plus');
			if (bid) {
				if (isPlus) itemQuantities[bid]++;
				else if (itemQuantities[bid] > 1) itemQuantities[bid]--;
				
				const valEl = document.getElementById(`qty-${bid}`);
				if (valEl) valEl.textContent = itemQuantities[bid];
			}
		});
	});

	// Add to Cart Logic
	document.querySelectorAll('.add-btn').forEach(btn => {
		btn.addEventListener('click', (e) => {
			const target = e.currentTarget as HTMLElement;
			const product = target.dataset.product;
			const id = target.dataset.id;
			if (product && id) {
				const qtyToAdd = itemQuantities[id];
				if (!cart[product]) cart[product] = { qty: 0 };
				cart[product].qty += qtyToAdd;
				
				// Success Feedback
				target.classList.add('success');
				setTimeout(() => target.classList.remove('success'), 2000);
				
				updateCartUI();
			}
		});
	});

	// Toggle Search/Panels
	document.querySelectorAll('.ingredients-toggle').forEach(btn => {
		btn.addEventListener('click', (e) => {
			const id = (e.currentTarget as HTMLElement).dataset.id;
			const panel = document.getElementById(`ingredients-${id}`);
			panel?.classList.add('active');
		});
	});

	document.querySelectorAll('.close-panel').forEach(btn => {
		btn.addEventListener('click', (e) => {
			const id = (e.currentTarget as HTMLElement).dataset.id;
			const panel = document.getElementById(`ingredients-${id}`);
			panel?.classList.remove('active');
		});
	});

	// Cart Toggle UI
	const openCart = () => {
		cartSidebar?.classList.add('active');
		cartOverlay?.classList.add('active');
	};
	const closeCart = () => {
		cartSidebar?.classList.remove('active');
		cartOverlay?.classList.remove('active');
	};

	cartToggle?.addEventListener('click', openCart);
	cartClose?.addEventListener('click', closeCart);
	cartOverlay?.addEventListener('click', closeCart);

	waBtn?.addEventListener('click', () => {
		const number = "27636936204";
		let total = 0;
		let message = "Hi RebelCo! I'm ready for the Gold Standard. My order:\n\n";
		Object.entries(cart).forEach(([name, item]: [string, any]) => {
			message += `• ${item.qty} x ${name} (R${item.qty * 100})\n`;
			total += item.qty * 100;
		});
		message += `\nTOTAL: R${total}\n\nNo Excuses.`;
		window.open(`https://wa.me/${number}?text=${encodeURIComponent(message)}`, '_blank');
	});

	// Intersection Observer for scroll tracking
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const id = entry.target.id;
				document.querySelectorAll('.nav-dot').forEach(dot => {
					dot.classList.toggle('active', dot.getAttribute('href') === `#${id}`);
				});
				if (header) {
					header.style.opacity = id === 'home' ? '0' : '1';
					header.style.pointerEvents = id === 'home' ? 'none' : 'auto';
				}
			}
		});
	}, { threshold: 0.5 });

	document.querySelectorAll('.page-section').forEach(section => observer.observe(section));

	scrollContainer?.addEventListener('scroll', () => {
		const scrolled = scrollContainer.scrollTop;
		document.querySelectorAll('.nature-bg').forEach((bg) => {
			(bg as HTMLElement).style.transform = `translateY(${scrolled * 0.1}px)`;
		});
	});
</script>

<style>
	:root {
		--accent: #ef4444;
		--accent-gold: #f59e0b;
		--bg-dark: #000;
		--panel-bg: rgba(0, 0, 0, 0.85);
	}

	/* Fix Horizontal Scroll */
	html, body {
		overflow-x: hidden;
		width: 100%;
		margin: 0;
		padding: 0;
		background: #000;
	}

	.scroll-container {
		height: 100vh;
		overflow-y: auto;
		scroll-snap-type: y mandatory;
		scroll-behavior: smooth;
	}

	.page-section {
		height: 100vh;
		width: 100vw;
		scroll-snap-align: start;
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.nature-bg {
		position: absolute;
		inset: -10%;
		background-size: cover;
		background-position: center;
		filter: brightness(0.3);
		z-index: 1;
		transition: transform 0.1s linear;
	}

	/* Layout Bases */
	.split-layout {
		display: grid;
		grid-template-columns: 1fr 1.2fr 1fr;
		width: 90%;
		max-width: 1600px;
		height: 80vh;
		position: relative;
		z-index: 2;
		gap: 2rem;
	}

	.center-panel {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.hero-image-container {
		width: 100%;
		max-width: 450px;
		margin-bottom: 1.5rem;
		transition: transform 0.5s ease;
	}
	.hero-img { width: 100%; filter: drop-shadow(0 20px 60px rgba(0,0,0,0.8)); }
	.hero-logo {
		width: 320px;
		height: auto;
		filter: drop-shadow(0 0 40px rgba(0,0,0,0.8));
		margin-bottom: 2rem;
		display: block !important;
	}

	.about-rebel-box {
		max-width: 600px;
		margin: 2rem auto;
		padding: 2rem;
		background: rgba(0,0,0,0.4);
		backdrop-filter: blur(10px);
		border-left: 3px solid var(--accent-gold);
		font-family: 'Staatliches', cursive;
		font-size: 1.25rem;
		color: #fff;
		text-align: left;
		line-height: 1.4;
	}
	.about-rebel-box p {
		margin-bottom: 1rem;
		letter-spacing: 0.05em;
	}
	.about-rebel-box p:last-child { margin-bottom: 0; }
	/* Gold Standard Controls */
	.gold-standard {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-top: 1.5rem;
	}

	.qty-selector {
		display: flex;
		align-items: center;
		background: rgba(255,255,255,0.1);
		border-radius: 4px;
		border: 1px solid rgba(255,255,255,0.2);
		overflow: hidden;
	}
	.qty-btn {
		background: none;
		border: none;
		color: #fff;
		padding: 0.5rem 1rem;
		font-family: 'Staatliches', cursive;
		font-size: 1.4rem;
		cursor: pointer;
		transition: background 0.3s;
	}
	.qty-btn:hover { background: rgba(255,255,255,0.1); }
	.qty-value {
		min-width: 40px;
		text-align: center;
		font-family: 'Staatliches', cursive;
		font-size: 1.4rem;
		color: var(--accent-gold);
	}

	.add-btn.premium {
		background: var(--accent-gold);
		color: #000;
		border: none;
		padding: 0.8rem 2.5rem;
		font-family: 'Staatliches', cursive;
		font-size: 1.3rem;
		cursor: pointer;
		position: relative;
		transition: all 0.3s;
		overflow: hidden;
	}
	.add-btn.premium:hover { transform: scale(1.05); box-shadow: 0 0 20px rgba(245, 158, 11, 0.4); }
	.success-check {
		position: absolute;
		inset: 0;
		background: #22c55e;
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		transform: translateY(100%);
		transition: transform 0.3s;
	}
	.add-btn.success .success-check { transform: translateY(0); }

	.price-tag {
		font-family: 'Bangers', cursive;
		font-size: 2.5rem;
		color: #fff;
		margin: 0.5rem 0;
		text-shadow: 0 0 15px var(--accent-gold);
	}

	.ingredients-toggle {
		background: none;
		border: 1px solid rgba(255,255,255,0.3);
		color: #999;
		padding: 0.5rem 1rem;
		margin-top: 1rem;
		font-family: 'Staatliches', cursive;
		font-size: 0.9rem;
		cursor: pointer;
		transition: all 0.3s;
		display: none; /* Only show on mobile */
	}

	/* Text Panels */
	.text-panel {
		background: var(--panel-bg);
		backdrop-filter: blur(30px);
		padding: 2.5rem;
		border-radius: 4px;
		border: 1px solid rgba(255,255,255,0.1);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.bullet {
		font-family: 'Staatliches', cursive;
		font-size: 1.35rem;
		color: #fff;
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
		position: relative;
		line-height: 1.1;
	}
	.bullet::before {
		content: '•';
		position: absolute;
		left: 0;
		color: var(--accent-gold);
	}

	/* Cart Sidebar Gold */
	.cart-trigger {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		width: 65px;
		height: 65px;
		background: var(--accent-gold);
		border-radius: 50%;
		border: none;
		cursor: pointer;
		z-index: 2000;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 10px 30px rgba(0,0,0,0.5);
		transition: transform 0.3s;
	}
	.cart-trigger:hover { transform: scale(1.1) rotate(-10deg); }
	.cart-trigger svg { width: 30px; height: 30px; color: #000; }
	.cart-count {
		position: absolute;
		top: 0;
		right: 0;
		background: #000;
		color: #fff;
		width: 24px;
		height: 24px;
		border-radius: 50%;
		font-family: 'Staatliches', cursive;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 2px solid var(--accent-gold);
	}

	.cart-sidebar {
		position: fixed;
		top: 0;
		right: 0;
		width: 400px;
		height: 100vh;
		background: #0a0a0a;
		z-index: 3000;
		transform: translateX(100%);
		transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1);
		display: flex;
		flex-direction: column;
		border-left: 1px solid rgba(255,255,255,0.1);
	}
	.cart-sidebar.active { transform: translateX(0); }
	.cart-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.8);
		z-index: 2900;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.4s;
	}
	.cart-overlay.active { opacity: 1; pointer-events: auto; }

	.cart-header-gold {
		padding: 2rem;
		border-bottom: 1px solid rgba(255,255,255,0.1);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.cart-header-gold h3 { color: var(--accent-gold); margin: 0; font-size: 1.8rem; }
	.cart-header-gold button { background: none; border: 1px solid #444; color: #888; padding: 0.5rem 1rem; font-family: 'Staatliches'; cursor: pointer; }

	.cart-items-scroll {
		flex: 1;
		overflow-y: auto;
		padding: 2rem;
	}
	.cart-item-gold {
		padding-bottom: 1.5rem;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}
	.item-info { display: flex; justify-content: space-between; font-family: 'Staatliches'; font-size: 1.3rem; margin-bottom: 1rem; }
	.item-controls { display: flex; align-items: center; gap: 1rem; }
	.cart-qty-btn { background: none; border: 1px solid #333; color: #fff; width: 30px; height: 30px; cursor: pointer; }
