---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL | Handcrafted Tallow Soap">
	<main class="scroll-container">
		<!-- Section 1: REBEL Hero / Charcoal & Turmeric -->
		<section class="page-section charcoal-biome" id="charcoal">
			<div class="split-layout">
				<div class="benefits-panel">
					<div class="content-box">
						<p>• CHARCOAL ACTS LIKE A MAGNET, DRAWING OUT DEEP-SEATED DIRT, OIL, AND IMPURITIES FROM PORES.</p>
						<p>• PROVIDES GENTLE PHYSICAL EXFOLIATION, REMOVING DEAD SKIN CELLS FOR A SMOOTHER TEXTURE.</p>
					</div>
				</div>
				<div class="center-panel">
					<div class="hero-image-container">
						<img src="/charcoal_turmeric_hero.png" alt="REBEL Charcoal and Turmeric" class="hero-img" />
					</div>
					<div class="order-controls">
						<button class="add-btn" data-product="Charcoal & Turmeric">ADD TO ORDER</button>
					</div>
				</div>
				<div class="ingredients-panel">
					<div class="img-stack">
						<img src="/charcoal_left.png" alt="Charcoal" class="stack-img" />
						<div class="ingredients-text">
							<h3>INGREDIENTS</h3>
							<p>NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS,</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Desert of Turmeric Transition / Secondary Charcoal Info -->
		<section class="page-section turmeric-desert" id="turmeric-info">
			<div class="split-layout reverse">
				<div class="benefits-panel">
					<div class="content-box">
						<p>• TURMERIC IS A POTENT ANTI-INFLAMMATORY, REDUCING REDNESS, SWELLING, AND ACNE BREAKOUTS.</p>
						<p>• ITS ANTIOXIDANTS BRIGHTEN SKIN, EVEN OUT TONE, AND FADE DARK SPOTS OVER TIME.</p>
					</div>
				</div>
				<div class="ingredients-panel">
					<div class="img-stack">
						<img src="/turmeric_right.png" alt="Turmeric" class="stack-img" />
						<div class="ingredients-text">
							<h3>INGREDIENTS</h3>
							<p>NATURAL CLAYS, EXFOLIATING SEEDS, CHARCOAL, TURMERIC</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Section 3: Rooibos & Tea Tree -->
		<section class="page-section rooibos-biome" id="rooibos">
			<div class="split-layout">
				<div class="benefits-panel">
					<div class="content-box">
						<p>• RICH IN ANTIOXIDANTS</p>
						<p>• GENTLE EXFOLIATION AND SMOOTHER SKIN.</p>
						<p>• ANTI-INFLAMMATORY PROPERTIES HELP SOOTHE ECZEMA, ACNE, AND IRRITATION.</p>
						<p>• NATURALLY HYDRATING WITHOUT STRIPPING THE SKIN'S ESSENTIAL MOISTURE BARRIER.</p>
					</div>
				</div>
				<div class="center-panel">
					<div class="hero-image-container">
						<img src="/rooibos_hero.png" alt="REBEL Rooibos & Tea Tree" class="hero-img" />
					</div>
					<div class="order-controls">
						<button class="add-btn" data-product="Rooibos & Tea Tree">ADD TO ORDER</button>
					</div>
				</div>
				<div class="ingredients-panel">
					<div class="img-stack">
						<img src="/rooibos_top.png" alt="Rooibos Top" class="stack-img" />
						<img src="/rooibos_bottom.png" alt="Rooibos Bottom" class="stack-img" />
						<div class="ingredients-text">
							<h3>INGREDIENTS</h3>
							<p>NATURAL CLAYS. EXFOLIATING SEEDS. ROOIBOS. TEE TREE</p>
							<p>NATURAL TALLOW, PALM OIL, COCONUT OIL. ESSENTIAL OILS,</p>
						</div>
					</div>
					<div class="extra-benefits">
						<p>• CAFFEINE IN TEA TREE HELPS REDUCE UNDER-EYE PUFFINESS EFFECTIVELY.</p>
						<p>• ANTISEPTIC AND ANTIBACTERIAL TO CLEANSE PORES AND PREVENT BREAKOUTS.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Cart Sidebar -->
		<div class="cart-floating" id="cart-drawer">
			<div class="cart-header">YOUR REBEL ORDER</div>
			<div id="cart-list" class="cart-list">
				<p class="empty-msg">CART IS EMPTY</p>
			</div>
			<button id="whatsapp-link" class="wa-btn" disabled>ORDER VIA WHATSAPP</button>
		</div>

		<!-- Nav Dots -->
		<nav class="scroll-nav">
			<a href="#charcoal" class="nav-dot active"></a>
			<a href="#turmeric-info" class="nav-dot"></a>
			<a href="#rooibos" class="nav-dot"></a>
		</nav>
	</main>
</Layout>

<script>
	let cart = {};

	const cartList = document.getElementById('cart-list');
	const waBtn = document.getElementById('whatsapp-link');

	function updateCartUI() {
		const items = Object.entries(cart);
		if (items.length === 0) {
			cartList.innerHTML = '<p class="empty-msg">CART IS EMPTY</p>';
			waBtn.disabled = true;
			return;
		}

		cartList.innerHTML = items.map(([name, qty]) => `
			<div class="cart-item">
				<span>${qty} x ${name}</span>
				<button class="remove-btn" onclick="document.dispatchEvent(new CustomEvent('remove', {detail: '${name}'}))">×</button>
			</div>
		`).join('');
		waBtn.disabled = false;
	}

	document.querySelectorAll('.add-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const product = btn.dataset.product;
			cart[product] = (cart[product] || 0) + 1;
			updateCartUI();
		});
	});

	document.addEventListener('remove', (e) => {
		delete cart[e.detail];
		updateCartUI();
	});

	waBtn.addEventListener('click', () => {
		const number = "27636936204";
		let message = "Hi RebelCo! I'd like to request a quote for:\n\n";
		Object.entries(cart).forEach(([name, qty]) => {
			message += `• ${qty} x ${name}\n`;
		});
		window.open(`https://wa.me/${number}?text=${encodeURIComponent(message)}`, '_blank');
	});

	// Intersection Observer for Nav Dots
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				document.querySelectorAll('.nav-dot').forEach(dot => {
					dot.classList.toggle('active', dot.getAttribute('href') === `#${entry.target.id}`);
				});
			}
		});
	}, { threshold: 0.5 });

	document.querySelectorAll('.page-section').forEach(section => observer.observe(section));
</script>

<style>
	.scroll-container {
		height: 100vh;
		overflow-y: auto;
		scroll-snap-type: y mandatory;
		scroll-behavior: smooth;
	}

	.page-section {
		height: 100vh;
		width: 100vw;
		scroll-snap-align: start;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.split-layout {
		display: grid;
		grid-template-columns: 1fr 1.5fr 1fr;
		width: 100%;
		height: 100%;
	}

	.split-layout.reverse {
		grid-template-columns: 1fr 1fr;
	}

	.benefits-panel, .ingredients-panel {
		padding: 4rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background: #1a1a1a;
		color: #fff;
	}

	.content-box p {
		font-family: 'Staatliches', cursive;
		font-size: 1.4rem;
		margin-bottom: 2rem;
		text-transform: uppercase;
		line-height: 1.3;
	}

	.center-panel {
		background: #000;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		border-left: 1px solid rgba(255,255,255,0.1);
		border-right: 1px solid rgba(255,255,255,0.1);
	}

	.hero-image-container {
		width: 80%;
		max-width: 500px;
	}

	.hero-img {
		width: 100%;
		filter: drop-shadow(0 0 30px rgba(0,0,0,0.8));
	}

	.img-stack {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.stack-img {
		width: 100%;
		border: 1px solid rgba(255,255,255,0.1);
	}

	.ingredients-text h3 {
		font-family: 'Staatliches', cursive;
		color: #ef4444;
		font-size: 2rem;
		margin-top: 1.5rem;
	}

	.ingredients-text p {
		font-family: 'Staatliches', cursive;
		font-size: 1.2rem;
		opacity: 0.8;
	}

	/* Biome Specifics */
	.charcoal-biome { background: #000; }
	
	.turmeric-desert {
		background: #f59e0b;
		color: #000;
	}
	.turmeric-desert .benefits-panel, .turmeric-desert .ingredients-panel {
		background: #f59e0b;
		color: #000;
	}
	.turmeric-desert .ingredients-text h3 { color: #000; border-bottom: 2px solid #000; display: inline-block; }

	.rooibos-biome { background: #000; }
	.rooibos-biome .benefits-panel { border-right: 1px solid rgba(255,40,40,0.2); }

	/* Controls */
	.order-controls { margin-top: 2rem; }
	.add-btn {
		background: #ef4444;
		color: #fff;
		border: none;
		padding: 1rem 3rem;
		font-family: 'Staatliches', cursive;
		font-size: 1.5rem;
		cursor: pointer;
		transition: transform 0.2s;
	}
	.add-btn:hover { transform: scale(1.05); }

	/* Cart Drawer */
	.cart-floating {
		position: fixed;
		top: 2rem;
		right: 2rem;
		width: 280px;
		background: rgba(0,0,0,0.9);
		border: 1px solid rgba(255,255,255,0.1);
		padding: 1.5rem;
		backdrop-filter: blur(10px);
		z-index: 1000;
	}
	.cart-header { font-family: 'Staatliches', cursive; color: #ef4444; font-size: 1.2rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.2); }
	.cart-item { display: flex; justify-content: space-between; font-family: 'Staatliches', cursive; margin-bottom: 0.5rem; }
	.wa-btn {
		width: 100%;
		background: #25d366;
		color: #fff;
		border: none;
		padding: 0.8rem;
		font-family: 'Staatliches', cursive;
		margin-top: 1rem;
		cursor: pointer;
	}
	.wa-btn:disabled { opacity: 0.3; cursor: not-allowed; }

	/* Nav Dots */
	.scroll-nav {
		position: fixed;
		left: 2rem;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		z-index: 1000;
	}
	.nav-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: rgba(255,255,255,0.3);
		transition: all 0.3s;
	}
	.nav-dot.active { background: #ef4444; transform: scale(1.5); box-shadow: 0 0 10px #ef4444; }

	@media (max-width: 1024px) {
		.split-layout, .split-layout.reverse { grid-template-columns: 1fr; overflow-y: auto; }
		.page-section { height: auto; min-height: 100vh; scroll-snap-align: none; }
		.scroll-container { scroll-snap-type: none; }
		.center-panel { order: -1; padding: 4rem 0; }
		.cart-floating { position: static; width: 100%; border-radius: 0; }
	}
</style>
