<script is:inline>
(function() {
	var cart = {};

	// DYNAMIC INGREDIENT MAP FROM CANVA EXTRACTION
	var INGREDIENTS = {
		'tallow': { title: 'Pure Beef Tallow', text: '100% Pure rendered beef fat. Sourced from grass-fed, ethically raised cattle. Contains trace amounts of Vitamin D.' },
		'charcoal': { title: 'Charcoal & Turmeric', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Charcoal, Turmeric' },
		'rooibos': { title: 'Rooibos & Tea Tree', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Rooibos, Tee Tree' },
		'cocoa': { title: 'Cocoa Coconut Soap', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Cocoa, Coconut' },
		'rainforest': { title: 'Rainforest Herbs', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Mixed Herbs' },
		'oats': { title: 'Oats & Honey', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Oats, Honey' },
		'ocean': { title: 'Ocean Blue Soap', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Sea Sand, Jasmine Oil' },
		'aloe': { title: 'Aloe & Rosemary', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Aloe, Rosemary' },
		'grotman': { title: 'Grotman All-in-One', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds' },
		'shampoo': { title: 'Shampoo & Conditioner', text: 'Tallow, Jojoba Oil, Palm Oil, Coconut Oil, Caster Oil, Essential Oils, Natural Clays' },
		'salt': { title: 'Himalayan Salt Soap', text: 'Natural Tallow, Palm Oil, Coconut Oil, Essential Oils, Natural Clays, Exfoliating Seeds, Himalayan Salt' }
	};

	window.openIngredientModal = function(id) {
		var mod = document.getElementById('ingredients-modal');
		if(INGREDIENTS[id]) {
			document.getElementById('modal-title').innerText = INGREDIENTS[id].title;
			document.getElementById('modal-text').innerText = INGREDIENTS[id].text;
			mod.classList.add('visible');
		}
	};
	window.closeIngredientModal = function() {
		document.getElementById('ingredients-modal').classList.remove('visible');
	};

	function drawCart() {
		var body = document.getElementById('cart-body');
		var tally = document.getElementById('cart-tally');
		var total = document.getElementById('cart-total');
		var waBtn = document.getElementById('checkout-btn');
		var keys = Object.keys(cart);

		if (!body) return;

		if (keys.length === 0) {
			body.innerHTML = '<p class="cart-empty">YOUR CRATE IS EMPTY</p>';
			if (tally) tally.textContent = '0';
			if (tally) tally.style.display = 'none';
			if (total) total.textContent = 'R0';
			if (waBtn) waBtn.disabled = true;
			return;
		}

		var count = 0, sum = 0;
		var html = '';
		keys.forEach(function(pid) {
			var item = cart[pid];
			count += item.qty;
			var lineTotal = item.qty * item.price;
			sum += lineTotal;
			html += '<div class="cart-row">' +
				'<div class="cart-row-top"><span>' + item.name + '</span><span class="row-price">R' + lineTotal + '</span></div>' +
				'<div class="cart-row-btns">' +
				'<button onclick="rebelCartDec(\'' + pid + '\')" class="cv-btn">-</button>' +
				'<span class="cv-val">' + item.qty + '</span>' +
				'<button onclick="rebelCartInc(\'' + pid + '\')" class="cv-btn">+</button>' +
				'</div></div>';
		});

		body.innerHTML = html;
		if (tally) { tally.textContent = count.toString(); tally.style.display = 'flex'; }
		if (total) total.textContent = 'R' + sum;
		if (waBtn) waBtn.disabled = false;
	}

	window.rebelCartInc = function(pid) { if (cart[pid]) { cart[pid].qty++; drawCart(); } };
	window.rebelCartDec = function(pid) {
		if (cart[pid]) {
			cart[pid].qty--;
			if (cart[pid].qty <= 0) delete cart[pid];
			drawCart();
		}
	};

	document.addEventListener('DOMContentLoaded', function() {
		// ADD TO CRATE
		document.querySelectorAll('.add-crate-btn').forEach(function(btn) {
			btn.addEventListener('click', function() {
				var id = btn.getAttribute('data-id');
				var name = btn.getAttribute('data-name');
				var price = parseInt(btn.getAttribute('data-price'), 10);
				var qtyEl = document.getElementById('q-' + id);
				var q = qtyEl ? parseInt(qtyEl.innerText) : 1;
				
				if (!cart[id]) cart[id] = { name: name, price: price, qty: 0 };
				cart[id].qty += q;
				
				// Feedback
				var originalText = btn.innerText;
				btn.innerText = "✓ Added";
				btn.classList.add('added');
				setTimeout(function() { 
					btn.innerText = originalText; 
					btn.classList.remove('added'); 
				}, 1500);
				
				if (qtyEl) qtyEl.innerText = '1';
				
				drawCart();
			});
		});

		// CART PANEL LOGIC
		var cartPanel = document.getElementById('cart-panel');
		var cartShield = document.getElementById('cart-shield');
		var cartOpen = document.getElementById('cart-open');
		var cartExit = document.getElementById('cart-exit');

		function openCart() {
			if (cartPanel) cartPanel.classList.add('visible');
			if (cartShield) cartShield.classList.add('visible');
		}
		function closeCart() {
			if (cartPanel) cartPanel.classList.remove('visible');
			if (cartShield) cartShield.classList.remove('visible');
		}

		if (cartOpen) cartOpen.addEventListener('click', openCart);
		if (cartExit) cartExit.addEventListener('click', closeCart);
		if (cartShield) cartShield.addEventListener('click', closeCart);

		// CLOSE INGREDIENTS ON BACKGROUND CLICK
		var bgClick = document.getElementById('ingredients-modal');
		if(bgClick) {
			bgClick.addEventListener('click', function(e) {
				if(e.target === bgClick) closeIngredientModal();
			});
		}

		// WHATSAPP CHECKOUT
		var waBtn = document.getElementById('checkout-btn');
		if (waBtn) waBtn.addEventListener('click', function() {
			var num = "27636936204";
			var total = 0;
			var msg = "Hi RebelCo! My Natural Rebellion crate order:\n\n";
			Object.keys(cart).forEach(function(pid) {
				var item = cart[pid];
				var lineTotal = item.qty * item.price;
				msg += '• ' + item.qty + ' x ' + item.name + ' (R' + lineTotal + ')\n';
				total += lineTotal;
			});
			msg += '\nTOTAL: R' + total + '\n\nI am ready for the pure rebellion.';
			window.open('https://wa.me/' + num + '?text=' + encodeURIComponent(msg), '_blank');
		});

		// SMOOTH SCROLL FOR NAV LINKS
		document.querySelectorAll('.desktop-nav a').forEach(anchor => {
			anchor.addEventListener('click', function (e) {
				e.preventDefault();
				document.querySelector(this.getAttribute('href')).scrollIntoView({
					behavior: 'smooth'
				});
			});
		});

		// PREVENT SCROLL RESTORATION ISSUES
		if ('scrollRestoration' in history) {
			history.scrollRestoration = 'manual';
		}
	});

})();
</script>

