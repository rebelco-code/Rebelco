---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL | Choose Your Disruption">
	<main class="gateway-container">
		<!-- Section selection split -->
		<div class="gateway-split">
			<!-- Soap Side -->
			<a href="/soap" class="gateway-side soap-side">
				<div class="gateway-bg" style="background-image: url('https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&q=80&w=1920');"></div>
				<div class="gateway-content">
					<div class="side-label">CINEMATIC SKINCARE</div>
					<h2 class="side-title">THE SOAP<br/>DISRUPTION</h2>
					<div class="explore-btn">ENTER BIOMES</div>
				</div>
			</a>

			<!-- Laser Side -->
			<a href="/gifts" class="gateway-side laser-side">
				<div class="gateway-bg" style="background-image: url('https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&q=80&w=1920');"></div>
				<div class="gateway-content">
					<div class="side-label">INDUSTRIAL PRECISION</div>
					<h2 class="side-title">THE LASER<br/>WORKSHOP</h2>
					<div class="explore-btn">EXPLORE GIFTS</div>
				</div>
			</a>
		</div>

		<!-- Central Logo Overlay -->
		<div class="central-branding">
			<img src="/logo.png" alt="REBEL Logo" class="center-logo" />
			<div class="mission-text">
				<p>FAMILY OWNED. ALL NATURAL. CAREFULLY HANDCRAFTED.</p>
				<p>REBEL AGAINST THE NORM.</p>
			</div>
		</div>
	</main>
</Layout>

<style>
	:root {
		--gold: #f59e0b;
		--dark: #000;
	}

	.gateway-container {
		height: 100vh;
		width: 100vw;
		overflow: hidden;
		position: relative;
		background: #000;
	}

	.gateway-split {
		display: flex;
		height: 100%;
		width: 100%;
	}

	.gateway-side {
		flex: 1;
		position: relative;
		overflow: hidden;
		text-decoration: none;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: flex 0.8s cubic-bezier(0.23, 1, 0.32, 1);
	}

	.gateway-side:hover {
		flex: 1.4;
	}

	.gateway-bg {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		filter: brightness(0.4) grayscale(0.5);
		transition: filter 0.8s, transform 0.8s;
		z-index: 1;
	}

	.gateway-side:hover .gateway-bg {
		filter: brightness(0.6) grayscale(0);
		transform: scale(1.05);
	}

	.gateway-content {
		position: relative;
		z-index: 10;
		text-align: center;
		color: #fff;
		pointer-events: none;
	}

	.side-label {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		letter-spacing: 0.4rem;
		margin-bottom: 1rem;
		color: var(--gold);
		opacity: 0.8;
	}

	.side-title {
		font-family: 'Bangers', cursive;
		font-size: clamp(2.5rem, 5vw, 5rem);
		line-height: 0.9;
		margin: 0;
		text-shadow: 2px 2px 20px rgba(0,0,0,0.8);
	}

	.explore-btn {
		margin-top: 2rem;
		display: inline-block;
		padding: 1rem 2.5rem;
		border: 1px solid #fff;
		font-family: 'Staatliches', cursive;
		font-size: 1.2rem;
		letter-spacing: 0.1rem;
		transition: 0.3s;
	}

	.gateway-side:hover .explore-btn {
		background: #fff;
		color: #000;
	}

	/* Central Overlay */
	.central-branding {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 20;
		text-align: center;
		pointer-events: none;
	}

	.center-logo {
		width: 180px;
		height: auto;
		filter: drop-shadow(0 0 40px rgba(0,0,0,0.9));
		margin-bottom: 2rem;
	}

	.mission-text {
		font-family: 'Staatliches', cursive;
		color: #fff;
		font-size: 1.1rem;
		opacity: 0.9;
		letter-spacing: 0.1rem;
	}

	.mission-text p { margin: 0.5rem 0; }

	/* Separator Line */
	.gateway-side::after {
		content: '';
		position: absolute;
		right: 0;
		top: 10%;
		bottom: 10%;
		width: 1px;
		background: rgba(255,255,255,0.2);
		z-index: 5;
	}
	.laser-side::after { display: none; }

	@media (max-width: 768px) {
		.gateway-split { flex-direction: column; }
		.gateway-side:hover { flex: 1; }
		.central-branding { top: 50%; width: 100%; }
		.center-logo { width: 120px; }
		.side-title { font-size: 3rem; }
		.gateway-side::after {
			right: 10%;
			left: 10%;
			bottom: 0;
			top: auto;
			width: auto;
			height: 1px;
		}
	}
</style>
