---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL TALLOW CO. | Natural Rebellion">
	<!-- Film Grain Overlay -->
	<div class="film-grain"></div>

	<!-- Header Nav -->
	<header class="main-header" id="main-header">
		<div class="header-inner">
			<a href="/" class="logo-text">REBEL TALLOW CO.</a>
			<nav class="desktop-nav">
				<a href="#shop">SHOP</a>
				<a href="#rebellion">THE REBELLION</a>
				<a href="#markets">MARKETS</a>
			</nav>
			<div class="cart-anchor">
				<button id="cart-open" class="wa-btn">
					<span class="wa-icon">🛒</span> <span id="cart-tally">0</span> ITEMS
				</button>
			</div>
		</div>
	</header>

	<main class="scroll-container">
		<!-- HERO SECTION -->
		<section class="hero-section" id="home">
			<div class="hero-bg"></div>
			<div class="smoke-overlay"></div>
			<div class="hero-content">
				<h1 class="distressed-gold title-main">REBEL TALLOW CO.</h1>
				<h2 class="hero-slogan">NATURAL REBELLION</h2>
				<div class="hero-actions">
					<a href="#shop" class="gold-btn">SHOP NOW</a>
					<a href="#rebellion" class="ghost-btn">EXPLORE THE REBELLION</a>
				</div>
			</div>
		</section>

		<!-- THE REBELLION / MANIFESTO -->
		<section class="rebellion-section" id="rebellion">
			<div class="rebellion-content">
				<img src="https://images.unsplash.com/photo-1629853381617-6d601dff7244?auto=format&fit=crop&q=80&w=400" alt="Cracked Skull" class="small-skull"/>
				<h2 class="distressed-gold section-title">THE REBELLION</h2>
				<div class="manifesto">
					<p>WE REJECT THE CHEMICAL NORM. WE RETURN TO THE ANCESTRAL, THE RAW, THE PURE.</p>
					<p>Our skincare is a defiant act against synthetic modern industry. Rendered by hand, sourced ethically, and crafted for those who demand uncompromising quality.</p>
					<p>No synthetic fragrances. No seed oils. Just sheer, powerful natural resilience.</p>
				</div>
			</div>
		</section>

		<!-- SHOP / COLLECTION PAGE -->
		<section class="shop-section" id="shop">
			<div class="shop-content">
				<h2 class="distressed-gold section-title">Shop the Natural Rebellion</h2>
				
				<div class="rustic-grid">
					<!-- PURE BEEF TALLOW -->
					<div class="product-card">
						<div class="card-img-wrap">
							<img src="https://images.unsplash.com/photo-1621607512214-68297480165e?auto=format&fit=crop&q=80&w=800" alt="Pure Tallow Jar"/>
						</div>
						<div class="card-info">
							<h3>Pure Beef Tallow (500ml Jar)</h3>
							<p class="price">R180</p>
							<div class="card-actions">
								<div class="qty-selector">
									<button class="qty-btn" onclick="document.getElementById('q-tallow').innerText = Math.max(1, parseInt(document.getElementById('q-tallow').innerText)-1)">-</button>
									<span id="q-tallow" class="qty-val">1</span>
									<button class="qty-btn" onclick="document.getElementById('q-tallow').innerText = parseInt(document.getElementById('q-tallow').innerText)+1">+</button>
								</div>
								<button class="gold-btn add-to-crate" data-id="tallow" data-name="Pure Beef Tallow 500ml" data-price="180">ADD TO CRATE</button>
							</div>
						</div>
					</div>

					<!-- CHARCOAL SOAP -->
					<div class="product-card">
						<div class="card-img-wrap">
							<img src="/charcoal_turmeric_hero.png" alt="Charcoal Soap"/>
						</div>
						<div class="card-info">
							<h3>Charcoal & Turmeric Soap</h3>
							<p class="price">R180</p>
							<div class="card-actions">
								<div class="qty-selector">
									<button class="qty-btn" onclick="document.getElementById('q-charcoal').innerText = Math.max(1, parseInt(document.getElementById('q-charcoal').innerText)-1)">-</button>
									<span id="q-charcoal" class="qty-val">1</span>
									<button class="qty-btn" onclick="document.getElementById('q-charcoal').innerText = parseInt(document.getElementById('q-charcoal').innerText)+1">+</button>
								</div>
								<button class="gold-btn add-to-crate" data-id="charcoal" data-name="Charcoal & Turmeric Soap" data-price="180">ADD TO CRATE</button>
							</div>
						</div>
					</div>

					<!-- ROOIBOS SOAP -->
					<div class="product-card">
						<div class="card-img-wrap">
							<img src="/rooibos_hero.png" alt="Rooibos Soap"/>
						</div>
						<div class="card-info">
							<h3>Rooibos & Tea Tree Soap</h3>
							<p class="price">R180</p>
							<div class="card-actions">
								<div class="qty-selector">
									<button class="qty-btn" onclick="document.getElementById('q-rooibos').innerText = Math.max(1, parseInt(document.getElementById('q-rooibos').innerText)-1)">-</button>
									<span id="q-rooibos" class="qty-val">1</span>
									<button class="qty-btn" onclick="document.getElementById('q-rooibos').innerText = parseInt(document.getElementById('q-rooibos').innerText)+1">+</button>
								</div>
								<button class="gold-btn add-to-crate" data-id="rooibos" data-name="Rooibos & Tea Tree Soap" data-price="180">ADD TO CRATE</button>
							</div>
						</div>
					</div>

					<!-- SKILLET -->
					<div class="product-card">
						<div class="card-img-wrap">
							<!-- Using a sizzling skillet Unsplash image -->
							<img src="https://images.unsplash.com/photo-1544148103-0773bf10d330?auto=format&fit=crop&q=80&w=800" alt="Sizzling Skillet"/>
						</div>
						<div class="card-info">
							<h3>Cast Iron Skillet (Seasoned)</h3>
							<p class="price">R450</p>
							<div class="card-actions">
								<div class="qty-selector">
									<button class="qty-btn" onclick="document.getElementById('q-skillet').innerText = Math.max(1, parseInt(document.getElementById('q-skillet').innerText)-1)">-</button>
									<span id="q-skillet" class="qty-val">1</span>
									<button class="qty-btn" onclick="document.getElementById('q-skillet').innerText = parseInt(document.getElementById('q-skillet').innerText)+1">+</button>
								</div>
								<button class="gold-btn add-to-crate" data-id="skillet" data-name="Cast Iron Skillet" data-price="450">ADD TO CRATE</button>
							</div>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- MARKETS / FIND US PAGE -->
		<section class="markets-section" id="markets">
			<div class="markets-bg"></div>
			<div class="markets-content">
				<h2 class="distressed-gold section-title">FIND US AT THE MARKETS</h2>
				<ul class="market-list">
					<li>★ THE OLD BISCUIT MILL - CAPE TOWN ★</li>
					<li>★ ORANJEZICHT CITY FARM MARKET ★</li>
					<li>★ ROOT44 MARKET - STELLENBOSCH ★</li>
					<li>★ SHONGWENI FARMERS MARKET - KZN ★</li>
				</ul>
				<div class="crate-visuals">
					<img src="https://images.unsplash.com/photo-1596733430284-f743727546a6?auto=format&fit=crop&q=80&w=600" alt="Wooden Crates" class="crate-img" />
				</div>
			</div>
		</section>

		<!-- FOOTER -->
		<footer class="main-footer">
			<div class="footer-content">
				<img src="https://images.unsplash.com/photo-1629853381617-6d601dff7244?auto=format&fit=crop&q=80&w=400" alt="Big Skull" class="footer-skull"/>
				<h2 class="distressed-gold footer-slogan">NATURAL REBELLION</h2>
				<p class="footer-copy">&copy; 2026 REBEL TALLOW CO. SOUTH AFRICA 🇿🇦</p>
			</div>
		</footer>

		<!-- CART SHIELD AND DRAWER -->
		<div class="cart-shield" id="cart-shield"></div>
		<div class="cart-panel" id="cart-panel">
			<div class="cart-top">
				<h3>YOUR CRATE</h3>
				<button id="cart-exit" class="close-cart-btn">✕</button>
			</div>
			<div id="cart-body" class="cart-body">
				<p class="cart-empty">YOUR CRATE IS EMPTY</p>
			</div>
			<div class="cart-bottom">
				<div class="cart-math"><span>TOTAL</span><span id="cart-total">R0</span></div>
				<button id="checkout-btn" class="checkout-btn" disabled>ORDER ON WHATSAPP</button>
			</div>
		</div>
	</main>
</Layout>

<script is:inline>
(function() {
	var cart = {};

	function drawCart() {
		var body = document.getElementById('cart-body');
		var tally = document.getElementById('cart-tally');
		var total = document.getElementById('cart-total');
		var waBtn = document.getElementById('checkout-btn');
		var keys = Object.keys(cart);

		if (!body) return;

		if (keys.length === 0) {
			body.innerHTML = '<p class="cart-empty">YOUR CRATE IS EMPTY</p>';
			if (tally) tally.textContent = '0';
			if (total) total.textContent = 'R0';
			if (waBtn) waBtn.disabled = true;
			return;
		}

		var count = 0, sum = 0;
		var html = '';
		keys.forEach(function(pid) {
			var item = cart[pid];
			count += item.qty;
			var lineTotal = item.qty * item.price;
			sum += lineTotal;
			html += '<div class="cart-row">' +
				'<div class="cart-row-top"><span>' + item.name + '</span><span class="row-price">R' + lineTotal + '</span></div>' +
				'<div class="cart-row-btns">' +
				'<button onclick="rebelCartDec(\'' + pid + '\')" class="cv-btn">-</button>' +
				'<span class="cv-val">' + item.qty + '</span>' +
				'<button onclick="rebelCartInc(\'' + pid + '\')" class="cv-btn">+</button>' +
				'</div></div>';
		});

		body.innerHTML = html;
		if (tally) tally.textContent = count.toString();
		if (total) total.textContent = 'R' + sum;
		if (waBtn) waBtn.disabled = false;
	}

	window.rebelCartInc = function(pid) { if (cart[pid]) { cart[pid].qty++; drawCart(); } };
	window.rebelCartDec = function(pid) {
		if (cart[pid]) {
			cart[pid].qty--;
			if (cart[pid].qty <= 0) delete cart[pid];
			drawCart();
		}
	};

	document.addEventListener('DOMContentLoaded', function() {
		// ADD TO CRATE
		document.querySelectorAll('.add-to-crate').forEach(function(btn) {
			btn.addEventListener('click', function() {
				var id = btn.getAttribute('data-id');
				var name = btn.getAttribute('data-name');
				var price = parseInt(btn.getAttribute('data-price'), 10);
				var qtyEl = document.getElementById('q-' + id);
				var q = qtyEl ? parseInt(qtyEl.innerText) : 1;
				
				if (!cart[id]) cart[id] = { name: name, price: price, qty: 0 };
				cart[id].qty += q;
				
				// Feedback
				var originalText = btn.innerText;
				btn.innerText = "✓ ADDED";
				btn.classList.add('added');
				setTimeout(function() { 
					btn.innerText = originalText; 
					btn.classList.remove('added'); 
				}, 1500);
				
				// Reset qty to 1
				if (qtyEl) qtyEl.innerText = '1';
				
				drawCart();
			});
		});

		// CART PANEL LOGIC
		var cartPanel = document.getElementById('cart-panel');
		var cartShield = document.getElementById('cart-shield');
		var cartOpen = document.getElementById('cart-open');
		var cartExit = document.getElementById('cart-exit');

		function openCart() {
			if (cartPanel) cartPanel.classList.add('visible');
			if (cartShield) cartShield.classList.add('visible');
		}
		function closeCart() {
			if (cartPanel) cartPanel.classList.remove('visible');
			if (cartShield) cartShield.classList.remove('visible');
		}

		if (cartOpen) cartOpen.addEventListener('click', openCart);
		if (cartExit) cartExit.addEventListener('click', closeCart);
		if (cartShield) cartShield.addEventListener('click', closeCart);

		// WHATSAPP CHECKOUT
		var waBtn = document.getElementById('checkout-btn');
		if (waBtn) waBtn.addEventListener('click', function() {
			var num = "27636936204";
			var total = 0;
			var msg = "Hi RebelCo! My Natural Rebellion crate order:\n\n";
			Object.keys(cart).forEach(function(pid) {
				var item = cart[pid];
				var lineTotal = item.qty * item.price;
				msg += '• ' + item.qty + ' x ' + item.name + ' (R' + lineTotal + ')\n';
				total += lineTotal;
			});
			msg += '\nTOTAL: R' + total + '\n\nI am ready for the pure rebellion.';
			window.open('https://wa.me/' + num + '?text=' + encodeURIComponent(msg), '_blank');
		});

		// SMOOTH SCROLL FOR NAV LINKS
		document.querySelectorAll('.desktop-nav a').forEach(anchor => {
			anchor.addEventListener('click', function (e) {
				e.preventDefault();
				document.querySelector(this.getAttribute('href')).scrollIntoView({
					behavior: 'smooth'
				});
			});
		});

		// SCROLL EFFECTS
		var header = document.getElementById('main-header');
		window.addEventListener('scroll', function() {
			if (window.scrollY > 50) {
				header.classList.add('scrolled');
			} else {
				header.classList.remove('scrolled');
			}
		});
	});

})();
</script>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Rye&family=IM+Fell+English+SC&family=Inter:wght@400;600&display=swap');

	:root { 
		--gold: #d4af37;
		--gold-dark: #b5952f;
		--black:#050505;
		--dark-wood: #110c08;
		--text-light: #e5e5e5;
		--text-muted: #a0a0a0;
	}
	* { box-sizing: border-box; }
	html, body {
		margin: 0; padding: 0; background: var(--black); color: var(--text-light);
		font-family: 'Inter', sans-serif; overflow-x: hidden;
	}

	/* ── FILM GRAIN OVERLAY ──────────────────────────── */
	.film-grain {
		position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
		pointer-events: none; z-index: 9999;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.25'/%3E%3C/svg%3E");
		opacity: 0.15;
		mix-blend-mode: overlay;
	}

	/* ── TYPOGRAPHY ──────────────────────────────────── */
	.distressed-gold {
		font-family: 'Rye', cursive;
		color: var(--gold);
		text-shadow: 2px 2px 0px rgba(0,0,0,0.8), 0 0 15px rgba(212,175,55,0.3);
		letter-spacing: 2px;
	}

	/* ── HEADER ──────────────────────────────────────── */
	.main-header {
		position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
		padding: 1.5rem 2rem; transition: background 0.3s, padding 0.3s;
		background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
	}
	.main-header.scrolled {
		background: rgba(5,5,5,0.95);
		border-bottom: 2px solid rgba(212,175,55,0.2);
		padding: 1rem 2rem;
		backdrop-filter: blur(10px);
	}
	.header-inner { display: flex; justify-content: space-between; align-items: center; max-width: 1400px; margin: 0 auto; }
	.logo-text {
		font-family: 'Cinzel Decorative', serif; font-size: 1.8rem; font-weight: 900;
		color: var(--gold); text-decoration: none; text-shadow: 2px 2px 5px #000;
	}
	.desktop-nav a {
		font-family: 'IM Fell English SC', serif; color: var(--gold); text-decoration: none;
		margin: 0 1.5rem; font-size: 1.4rem; letter-spacing: 1px; transition: color 0.3s;
		text-shadow: 1px 1px 3px #000;
	}
	.desktop-nav a:hover { color: #fff; }
	.wa-btn {
		background: transparent; border: 2px solid var(--gold); color: var(--gold);
		padding: 0.6rem 1.2rem; cursor: pointer; font-family: 'IM Fell English SC', serif;
		font-size: 1.2rem; font-weight: bold; transition: all 0.3s; border-radius: 4px;
	}
	.wa-btn:hover { background: var(--gold); color: #000; }
	.wa-icon { font-size: 1.2rem; }

	/* ── BUTTONS ─────────────────────────────────────── */
	.gold-btn {
		display: inline-block; background: var(--gold); color: #000;
		padding: 1rem 2.5rem; font-family: 'Inter', sans-serif; font-weight: 700;
		font-size: 1.2rem; text-decoration: none; border: 2px solid var(--gold);
		text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: all 0.3s;
	}
	.gold-btn:hover { background: #000; color: var(--gold); box-shadow: 0 0 15px rgba(212,175,55,0.4); }
	.ghost-btn {
		display: inline-block; background: transparent; color: var(--gold);
		padding: 1rem 2.5rem; font-family: 'Inter', sans-serif; font-weight: 700;
		font-size: 1.2rem; text-decoration: none; border: 2px solid var(--gold);
		text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: all 0.3s;
	}
	.ghost-btn:hover { background: var(--gold); color: #000; }

	/* ── SECTIONS BASE ───────────────────────────────── */
	section { position: relative; width: 100vw; overflow: hidden; }

	/* ── HERO SECTION ────────────────────────────────── */
	.hero-section {
		height: 100vh; display: flex; align-items: center; justify-content: center;
		text-align: center; background-color: #050505;
	}
	.hero-bg {
		position: absolute; inset: 0;
		background: url('https://images.unsplash.com/photo-1542382257-80ddbfc7478d?auto=format&fit=crop&q=80&w=2000') center/cover;
		opacity: 0.4; filter: contrast(1.2) grayscale(0.2);
	}
	.smoke-overlay {
		position: absolute; inset: 0;
		background: radial-gradient(circle at center, rgba(5,5,5,0.2) 0%, rgba(5,5,5,1) 85%);
	}
	.hero-content { position: relative; z-index: 10; padding: 2rem; max-width: 900px; }
	.title-main { font-size: clamp(3rem, 8vw, 6rem); margin: 0 0 1rem 0; line-height: 1.1; }
	.hero-slogan {
		font-family: 'IM Fell English SC', serif; color: var(--text-light);
		font-size: clamp(1.5rem, 4vw, 3rem); margin: 0 0 3rem 0; text-shadow: 2px 2px 10px #000;
	}
	.hero-actions { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }

	/* ── THE REBELLION ───────────────────────────────── */
	.rebellion-section {
		background: var(--black); padding: 8rem 2rem; text-align: center;
		border-top: 1px solid rgba(212,175,55,0.2);
		border-bottom: 1px solid rgba(212,175,55,0.2);
	}
	.rebellion-content { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }
	.small-skull { width: 120px; filter: grayscale(1) contrast(1.5) brightness(0.8); margin-bottom: 1rem; mix-blend-mode: lighten; }
	.section-title { font-size: 3rem; margin: 0 0 2rem 0; }
	.manifesto p {
		font-family: 'IM Fell English SC', serif; font-size: 1.4rem; line-height: 1.6;
		margin-bottom: 1.5rem; color: var(--text-light); text-shadow: 1px 1px 2px #000;
	}
	.manifesto p:first-child { font-size: 1.8rem; color: var(--gold); }

	/* ── SHOP SECTION ────────────────────────────────── */
	.shop-section {
		background: #0d0d0d; padding: 6rem 2rem;
		background-image: radial-gradient(circle at center, rgba(26,17,10,0.5) 0%, #0d0d0d 100%);
	}
	.shop-content { max-width: 1400px; margin: 0 auto; }
	.shop-content .section-title { text-align: center; margin-bottom: 4rem; }
	.rustic-grid {
		display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 3rem;
	}
	.product-card {
		background: var(--dark-wood);
		border: 1px solid rgba(212,175,55,0.15); box-shadow: 0 10px 30px rgba(0,0,0,0.5);
		display: flex; flex-direction: column; transition: transform 0.3s, border-color 0.3s;
	}
	.product-card:hover { transform: translateY(-5px); border-color: rgba(212,175,55,0.5); }
	.card-img-wrap {
		width: 100%; height: 280px; overflow: hidden; background: #000;
		display: flex; align-items: center; justify-content: center; border-bottom: 1px solid rgba(212,175,55,0.15);
	}
	.card-img-wrap img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.8) contrast(1.2); transition: 0.3s; }
	.product-card:hover .card-img-wrap img { filter: brightness(1) contrast(1.1); transform: scale(1.05); }
	.card-info { padding: 2rem; display: flex; flex-direction: column; flex: 1; text-align: center; }
	.card-info h3 { font-family: 'IM Fell English SC', serif; font-size: 1.6rem; color: #fff; margin: 0 0 0.5rem 0; }
	.card-info .price { font-family: 'Rye', cursive; font-size: 2rem; color: var(--gold); margin: 0 0 1.5rem 0; }
	.card-actions { margin-top: auto; display: flex; flex-direction: column; gap: 1rem; align-items: center; }
	
	.qty-selector { display: flex; align-items: center; border: 1px solid #444; border-radius: 4px; overflow: hidden; background: #000; }
	.qty-btn { background: none; border: none; color: var(--gold); font-size: 1.2rem; padding: 0.5rem 1rem; cursor: pointer; transition: 0.2s; }
	.qty-btn:hover { background: #222; }
	.qty-val { color: #fff; font-weight: bold; width: 40px; text-align: center; font-size: 1.2rem; }
	
	.add-to-crate { width: 100%; }

	/* ── MARKETS SECTION ─────────────────────────────── */
	.markets-section {
		padding: 6rem 2rem; position: relative; text-align: center; background: #080808;
	}
	.markets-bg {
		position: absolute; inset: 0; background: url('https://images.unsplash.com/photo-1542382257-80ddbfc7478d?auto=format&fit=crop&q=80&w=2000') center/cover;
		opacity: 0.15; mix-blend-mode: luminosity;
	}
	.markets-content { position: relative; z-index: 10; max-width: 800px; margin: 0 auto; }
	.market-list { list-style: none; padding: 0; margin: 3rem 0; }
	.market-list li {
