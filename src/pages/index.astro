---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL | Handcrafted Tallow Soap">
	<main class="scroll-container">

		<!-- Sticky Header -->
		<header class="sticky-header" id="main-header">
			<a href="/"><img src="/logo.png" alt="REBEL Logo" class="sticky-logo" /></a>
		</header>

		<!-- Landing Section -->
		<section class="page-section landing-page" id="home">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="section-content landing-content">
				<img src="/logo.png" alt="REBEL Tallow Soap" class="hero-logo" />
				<h1 class="landing-tagline">HANDCRAFTED DISRUPTION</h1>
				<div class="about-rebel-box">
					<p>REBEL is family owned, all natural, soap and skin care product manufacturer.</p>
					<p>We rebel against harsh chemicals in our carefully-handcrafted disruption against the norm of modern skincare.</p>
					<p>Old techniques. Modern approach. Every age.</p>
				</div>
				<p class="scroll-hint">↓ SCROLL TO DISRUPT ↓</p>
			</div>
		</section>

		<!-- Charcoal & Turmeric -->
		<section class="page-section product-biome" id="charcoal">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1547234935-80c7145ec969?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="section-content product-layout">
				<div class="side-panel desktop-only">
					<p class="bullet-item">CHARCOAL ACTS LIKE A MAGNET, DRAWING OUT IMPURITIES.</p>
					<p class="bullet-item">GENTLE PHYSICAL EXFOLIATION FOR SMOOTHER TEXTURE.</p>
					<p class="bullet-item">TURMERIC REDUCES REDNESS AND BREAKOUTS.</p>
					<p class="bullet-item">ANTIOXIDANTS BRIGHTEN SKIN OVER TIME.</p>
				</div>
				<div class="main-interaction">
					<img src="/charcoal_turmeric_hero.png" alt="Charcoal & Turmeric" class="product-pure-img" />
					<h2 class="main-title">Charcoal & Turmeric</h2>
					<p class="main-price">R100</p>
					<div class="buying-tools">
						<div class="quantity-box">
							<button class="qty-dec" data-pid="charcoal">-</button>
							<span class="qty-count" id="qty-val-charcoal">1</span>
							<button class="qty-inc" data-pid="charcoal">+</button>
						</div>
						<button class="add-btn" data-name="Charcoal & Turmeric" data-pid="charcoal">
							<span class="add-label">ADD TO ORDER</span>
							<span class="add-ok">✓ ADDED</span>
						</button>
					</div>
					<button class="ing-open mobile-only" data-modal="modal-charcoal">SEE INGREDIENTS</button>
				</div>
				<div class="side-panel desktop-only">
					<h3 class="ing-title">INGREDIENTS</h3>
					<p class="ing-text">NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, CHARCOAL, TURMERIC</p>
					<p class="ing-extra">• DETOXIFIES PORES WITHOUT STRIPPING OILS.</p>
					<p class="ing-extra">• PROMOTES A RADIANT, EVEN SKIN TONE.</p>
				</div>
			</div>
		</section>
		<div class="mobile-modal" id="modal-charcoal">
			<div class="modal-box">
				<button class="modal-x" data-close="modal-charcoal">✕</button>
				<h3>INGREDIENTS</h3>
				<p>NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, CHARCOAL, TURMERIC</p>
				<hr/>
				<p class="bullet-item">CHARCOAL ACTS LIKE A MAGNET, DRAWING OUT IMPURITIES.</p>
				<p class="bullet-item">GENTLE PHYSICAL EXFOLIATION FOR SMOOTHER TEXTURE.</p>
				<p class="bullet-item">TURMERIC REDUCES REDNESS AND BREAKOUTS.</p>
			</div>
		</div>

		<!-- Rooibos & Tea Tree -->
		<section class="page-section product-biome" id="rooibos">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="section-content product-layout">
				<div class="side-panel desktop-only">
					<p class="bullet-item">RICH IN ANTIOXIDANTS FOR CELLULAR REPAIR.</p>
					<p class="bullet-item">GENTLE EXFOLIATION PROMOTING RADIANT SKIN.</p>
					<p class="bullet-item">ANTI-INFLAMMATORY HELPS SOOTHE ECZEMA.</p>
					<p class="bullet-item">NATURALLY HYDRATING BARRIER PROTECTION.</p>
				</div>
				<div class="main-interaction">
					<img src="/rooibos_hero.png" alt="Rooibos & Tea Tree" class="product-pure-img" />
					<h2 class="main-title">Rooibos & Tea Tree</h2>
					<p class="main-price">R100</p>
					<div class="buying-tools">
