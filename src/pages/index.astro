								</div>
							</div>
						</div>

						<!-- OCEAN BLUE SOAP -->
						<div class="product-card">
							<div class="rebel-stamp">Rebel</div>
							<div class="card-img-wrap">
								<img src="/canva_slide_7.png" alt="Ocean Blue Soap" class="label-photo"/>
							</div>
							<div class="card-bottom">
								<h3 class="prod-title">Ocean Blue</h3>
								<p class="price">R100</p>
								<div class="qty-control">
									<button onclick="document.getElementById('q-ocean').innerText = Math.max(1, parseInt(document.getElementById('q-ocean').innerText)-1)">-</button>
