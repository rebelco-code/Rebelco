---
import Layout from '../layouts/Layout.astro';
---

<Layout title="REBEL | Handcrafted Tallow Soap">
	<main class="scroll-container">
		<!-- Header / Logo -->
		<header class="sticky-header" id="main-header">
			<img src="/logo.png" alt="REBEL Logo" class="sticky-logo" />
		</header>
		
		<!-- Section 0: Landing Page (The Logo) -->
		<section class="page-section landing-page" id="home">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="center-panel landing-content">
				<img src="/logo.png" alt="REBEL Tallow Soap" class="hero-logo" />
				<h1 class="landing-tagline">HANDCRAFTED DISRUPTION</h1>
				<div class="scroll-indicator">
					<span>SCROLL TO DISRUPT</span>
					<div class="arrow"></div>
				</div>
			</div>
		</section>

		<!-- Section 1: Charcoal & Turmeric (Rooibos Vibe) -->
		<section class="page-section product-biome charcoal-biome" id="charcoal">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1512418490979-92798cccf340?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="split-layout">
				<div class="text-panel left">
					<div class="content-box">
						<p class="bullet">CHARCOAL ACTS LIKE A MAGNET, DRAWING OUT DEEP-SEATED DIRT, OIL, AND IMPURITIES.</p>
						<p class="bullet">PROVIDES GENTLE PHYSICAL EXFOLIATION FOR A SMOOTHER SKIN TEXTURE.</p>
						<p class="bullet">TURMERIC IS A POTENT ANTI-INFLAMMATORY, REDUCING REDNESS AND BREAKOUTS.</p>
						<p class="bullet">ITS ANTIOXIDANTS BRIGHTEN SKIN AND FADE DARK SPOTS OVER TIME.</p>
					</div>
				</div>
				<div class="center-panel">
					<div class="hero-image-container">
						<img src="/charcoal_turmeric_hero.png" alt="REBEL Charcoal and Turmeric" class="hero-img" />
					</div>
					<div class="order-controls">
						<button class="add-btn" data-product="Charcoal & Turmeric">ADD TO ORDER</button>
					</div>
				</div>
				<div class="text-panel right">
					<div class="ingredients-box">
						<h3 class="accent-text">INGREDIENTS</h3>
						<p>NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, CHARCOAL, TURMERIC</p>
						<div class="extra-benefits">
							<p>• DETOXIFIES PORES WITHOUT STRIPPING NATURAL OILS.</p>
							<p>• PROMOTES A RADIANT, EVEN SKIN TONE NATURALLY.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Section 2: Rooibos & Tea Tree (The Template) -->
		<section class="page-section product-biome rooibos-biome" id="rooibos">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="split-layout">
				<div class="text-panel left">
					<div class="content-box">
						<p class="bullet">RICH IN ANTIOXIDANTS FOR CELLULAR REPAIR AND PROTECTION.</p>
						<p class="bullet">GENTLE EXFOLIATION PROMOTING RADIANT AND SMOOTHER SKIN.</p>
						<p class="bullet">ANTI-INFLAMMATORY PROPERTIES HELP SOOTHE ECZEMA AND ACNE.</p>
						<p class="bullet">NATURALLY HYDRATING WITHOUT STRIPPING THE SKIN'S BARRIER.</p>
					</div>
				</div>
				<div class="center-panel">
					<div class="hero-image-container">
						<img src="/rooibos_hero.png" alt="REBEL Rooibos & Tea Tree" class="hero-img" />
					</div>
					<div class="order-controls">
						<button class="add-btn" data-product="Rooibos & Tea Tree">ADD TO ORDER</button>
					</div>
				</div>
				<div class="text-panel right">
					<div class="ingredients-box">
						<h3 class="accent-text">INGREDIENTS</h3>
						<p>NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, ROOIBOS, TEA TREE</p>
						<div class="extra-benefits">
							<p>• CAFFEINE IN TEA TREE REDUCES UNDER-EYE PUFFINESS.</p>
							<p>• ANTISEPTIC PROPERTIES TO CLEANSE AND PREVENT BREAKOUTS.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Section 3: Cocoa Coconut (No More Math) -->
		<section class="page-section product-biome cocoa-biome" id="cocoa">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="split-layout">
				<div class="text-panel left">
					<div class="content-box">
						<p class="bullet">COCONUT OIL DEEPLY MOISTURIZES AND STRENGTHENS SKIN BARRIER.</p>
						<p class="bullet">ANTIBACTERIAL PROPERTIES TO FIGHT ACNE-CAUSING BACTERIA.</p>
						<p class="bullet">CACAO IS PACKED WITH ANTIOXIDANTS FOR RADIANT GLOW.</p>
						<p class="bullet">IMPROVES SKIN ELASTICITY AND BOOSTS MICRO-CIRCULATION.</p>
					</div>
				</div>
				<div class="center-panel">
					<div class="hero-image-container">
						<img src="/cocoa_hero.png" alt="REBEL Cocoa Coconut" class="hero-img" />
					</div>
					<div class="order-controls">
						<button class="add-btn" data-product="Cocoa Coconut">ADD TO ORDER</button>
					</div>
				</div>
				<div class="text-panel right">
					<div class="ingredients-box">
						<h3 class="accent-text">INGREDIENTS</h3>
						<p>NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, COCOA, COCONUT</p>
						<div class="extra-benefits">
							<p>• INTENSE HYDRATION FOR DRY AND TIRED SKIN.</p>
							<p>• PROMOTES A YOUTHFUL, FIRM, AND SUPPLE APPEARANCE.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Section 4: Rainforest Herbs (Knysna Forest Vibe) -->
		<section class="page-section product-biome rainforest-biome" id="rainforest">
			<div class="nature-bg" style="background-image: url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&q=80&w=1920');"></div>
			<div class="split-layout">
				<div class="text-panel left">
					<div class="content-box">
						<p class="bullet">TALLOW IS BIO-IDENTICAL TO SEBUM FOR INTENSE MOISTURIZATION.</p>
						<p class="bullet">RICH IN VITAMINS A, D, E, AND K TO REPAIR SKIN CELLS.</p>
						<p class="bullet">MIXED HERBS PROVIDE SPECIFIC BOTANICAL ANTIOXIDANTS.</p>
						<p class="bullet">NATURAL CLEANSING WITHOUT STRIPPING ESSENTIAL OILS.</p>
					</div>
				</div>
				<div class="center-panel">
					<div class="hero-image-container">
						<img src="/rainforest_hero.png" alt="REBEL Rainforest Herbs" class="hero-img" />
					</div>
					<div class="order-controls">
						<button class="add-btn" data-product="Rainforest Herbs">ADD TO ORDER</button>
					</div>
				</div>
				<div class="text-panel right">
					<div class="ingredients-box">
						<h3 class="accent-text">INGREDIENTS</h3>
						<p>NATURAL TALLOW, PALM OIL, COCONUT OIL, ESSENTIAL OILS, NATURAL CLAYS, EXFOLIATING SEEDS, MIXED HERBS</p>
						<div class="extra-benefits">
							<p>• SOOTHES SENSITIVE SKIN WITH BOTANICAL EXTRACTS.</p>
							<p>• RESTORES THE SKIN'S NATURAL VITALITY AND BALANCE.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Cart Sidebar (Moved to Bottom Right) -->
		<div class="cart-floating" id="cart-drawer">
			<div class="cart-header">YOUR REBEL ORDER</div>
			<div id="cart-list" class="cart-list">
				<p class="empty-msg">CART IS EMPTY</p>
			</div>
			<button id="whatsapp-link" class="wa-btn" disabled>ORDER VIA WHATSAPP</button>
		</div>

		<!-- Nav Dots (Moved to Center Right) -->
		<nav class="scroll-nav">
			<a href="#home" class="nav-dot active" title="Home"></a>
			<a href="#charcoal" class="nav-dot" title="Charcoal"></a>
			<a href="#rooibos" class="nav-dot" title="Rooibos"></a>
			<a href="#cocoa" class="nav-dot" title="Cocoa"></a>
			<a href="#rainforest" class="nav-dot" title="Rainforest"></a>
		</nav>
	</main>
</Layout>

<script>
	let cart = {};

	const cartList = document.getElementById('cart-list');
	const waBtn = document.getElementById('whatsapp-link');
	const scrollContainer = document.querySelector('.scroll-container');
	const header = document.getElementById('main-header');

	function updateCartUI() {
		const items = Object.entries(cart);
		if (items.length === 0) {
			cartList.innerHTML = '<p class="empty-msg">CART IS EMPTY</p>';
			waBtn.disabled = true;
			return;
		}

		cartList.innerHTML = items.map(([name, qty]) => `
			<div class="cart-item">
				<span>${qty} x ${name}</span>
				<button class="remove-btn" data-product="${name}">×</button>
			</div>
		`).join('');
		waBtn.disabled = false;

		document.querySelectorAll('.remove-btn').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const product = (e.currentTarget as HTMLButtonElement).dataset.product;
				if (product) {
					delete cart[product];
					updateCartUI();
				}
			});
		});
	}

	document.querySelectorAll('.add-btn').forEach(btn => {
		btn.addEventListener('click', (e) => {
			const product = (e.currentTarget as HTMLButtonElement).dataset.product;
			if (product) {
				cart[product] = (cart[product] || 0) + 1;
				updateCartUI();
			}
		});
	});

	waBtn.addEventListener('click', () => {
		const number = "27636936204";
		let message = "Hi RebelCo! I'd like to request a quote for:\n\n";
		Object.entries(cart).forEach(([name, qty]) => {
			message += `• ${qty} x ${name}\n`;
		});
		window.open(`https://wa.me/${number}?text=${encodeURIComponent(message)}`, '_blank');
	});

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const id = entry.target.id;
				document.querySelectorAll('.nav-dot').forEach(dot => {
					dot.classList.toggle('active', dot.getAttribute('href') === `#${id}`);
				});
				
				// Show sticky header on all pages except home
				if (header) {
					header.style.opacity = id === 'home' ? '0' : '1';
					header.style.pointerEvents = id === 'home' ? 'none' : 'auto';
				}
			}
		});
	}, { threshold: 0.5 });

	document.querySelectorAll('.page-section').forEach(section => observer.observe(section));

	scrollContainer?.addEventListener('scroll', () => {
		const scrolled = scrollContainer.scrollTop;
		document.querySelectorAll('.nature-bg').forEach((bg) => {
			const bgEl = bg as HTMLElement;
			bgEl.style.transform = `translateY(${scrolled * 0.1}px)`;
		});
	});
</script>

<style>
	:root {
		--accent: #ef4444;
		--bg-dark: #000;
		--panel-bg: rgba(0, 0, 0, 0.7);
	}

	.scroll-container {
		height: 100vh;
		overflow-y: auto;
		scroll-snap-type: y mandatory;
		scroll-behavior: smooth;
		-webkit-overflow-scrolling: touch;
	}

	.page-section {
		height: 100vh;
		width: 100vw;
		scroll-snap-align: start;
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.nature-bg {
		position: absolute;
		inset: -10% -10% -10% -10%;
		background-size: cover;
		background-position: center;
		filter: brightness(0.35);
		z-index: 1;
		transition: transform 0.1s linear;
	}

	/* Landing Page Styles */
	.landing-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		z-index: 2;
		text-align: center;
	}

	.hero-logo {
		width: 320px;
		height: auto;
		filter: drop-shadow(0 0 40px rgba(0,0,0,0.8));
		margin-bottom: 2rem;
	}

	.landing-tagline {
		font-family: 'Bangers', cursive;
		font-size: clamp(2.5rem, 5vw, 5rem);
		color: #fff;
		letter-spacing: 0.2em;
		text-shadow: 0 5px 15px rgba(0,0,0,0.5);
	}

	.scroll-indicator {
		margin-top: 4rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		font-family: 'Staatliches', cursive;
		color: #fff;
		opacity: 0.6;
		animation: bounce 2s infinite;
	}

	.arrow {
		width: 15px;
		height: 15px;
		border-right: 3px solid #fff;
		border-bottom: 3px solid #fff;
		transform: rotate(45deg);
		margin-top: 1rem;
	}

	@keyframes bounce {
		0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
		40% { transform: translateY(-10px); }
		60% { transform: translateY(-5px); }
	}

	/* Product Section Styles (Standardized) */
	.split-layout {
		display: grid;
		grid-template-columns: 1fr 1.2fr 1fr;
		width: 90%;
		max-width: 1600px;
		height: 80vh;
		position: relative;
		z-index: 2;
		gap: 2rem;
	}

	.text-panel {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 2rem;
		background: var(--panel-bg);
		backdrop-filter: blur(25px);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 4px;
	}

	.content-box p.bullet {
		font-family: 'Staatliches', cursive;
		font-size: clamp(1rem, 1.5vw, 1.35rem);
		margin-bottom: 1.5rem;
		text-transform: uppercase;
		line-height: 1.2;
		color: #fff;
		position: relative;
		padding-left: 1.5rem;
	}

	.content-box p.bullet::before {
		content: '•';
		position: absolute;
		left: 0;
		color: var(--accent);
	}

	.center-panel {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		z-index: 2;
	}

	.hero-image-container {
		width: 100%;
		max-width: 420px;
		margin-bottom: 2rem;
	}

	.hero-img {
		width: 100%;
		filter: drop-shadow(0 25px 50px rgba(0,0,0,0.9));
	}

	.ingredients-box h3 {
		font-family: 'Bangers', cursive;
		font-size: 2.2rem;
		margin-bottom: 1.2rem;
		letter-spacing: 0.1em;
		color: var(--accent);
	}

	.ingredients-box p {
		font-family: 'Staatliches', cursive;
		font-size: clamp(0.9rem, 1.3vw, 1.15rem);
		color: #ddd;
		text-transform: uppercase;
		line-height: 1.4;
	}

	.extra-benefits {
		margin-top: 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255,255,255,0.2);
	}

	.extra-benefits p {
		font-family: 'Staatliches', cursive;
		color: #fff;
		font-size: 1rem;
		margin-bottom: 0.8rem;
		opacity: 0.85;
	}

	/* Controls */
	.order-controls { margin-top: 1rem; }
	.add-btn {
		background: var(--accent);
		color: #fff;
		border: none;
		padding: 0.8rem 3rem;
		font-family: 'Staatliches', cursive;
		font-size: 1.4rem;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		box-shadow: 0 10px 25px rgba(0,0,0,0.5);
	}
	.add-btn:hover { transform: translateY(-3px) scale(1.03); background: #fff; color: #000; }

	/* Cart Sidebar (Moved to Bottom Right) */
	.cart-floating {
		position: fixed;
		bottom: 2.5rem;
		right: 2.5rem;
		width: 280px;
		background: rgba(0,0,0,0.9);
		border: 1px solid rgba(255,255,255,0.15);
		padding: 1.5rem;
		backdrop-filter: blur(20px);
		z-index: 1000;
		border-radius: 8px;
		box-shadow: 0 15px 40px rgba(0,0,0,0.6);
	}
	.cart-header { font-family: 'Staatliches', cursive; color: var(--accent); font-size: 1.3rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.2); }
	.cart-item { display: flex; justify-content: space-between; font-family: 'Staatliches', cursive; margin-bottom: 0.6rem; align-items: center; font-size: 1.1rem; }
	.remove-btn { background: none; border: none; color: var(--accent); font-size: 1.6rem; cursor: pointer; line-height: 1; }
	.wa-btn {
		width: 100%;
		background: #25d366;
		color: #fff;
		border: none;
		padding: 1rem;
		font-family: 'Staatliches', cursive;
		font-size: 1.2rem;
		margin-top: 1rem;
		cursor: pointer;
		border-radius: 4px;
	}
	.wa-btn:disabled { background: #1a1a1a; color: #444; cursor: not-allowed; }

	.scroll-nav {
		position: fixed;
		right: 2.5rem;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		gap: 2rem;
		z-index: 1000;
	}
	.nav-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: rgba(255,255,255,0.2);
		transition: all 0.4s ease;
	}
	.nav-dot.active { background: var(--accent); transform: scale(1.6); box-shadow: 0 0 15px var(--accent); }

	.sticky-header {
		position: fixed;
		top: 2.5rem;
		left: 2.5rem;
		z-index: 1100;
		mix-blend-mode: exclusion;
		transition: opacity 0.4s ease;
	}
	.sticky-logo { width: 75px; height: auto; }

	@media (max-width: 1200px) {
		.split-layout { grid-template-columns: 1fr 1.2fr; }
		.text-panel.right { display: none; }
		.cart-floating { width: 240px; }
	}

	@media (max-width: 768px) {
		.split-layout { grid-template-columns: 1fr; height: auto; padding-top: 6rem; }
		.page-section { height: auto; min-height: 100vh; padding: 4rem 1.5rem; }
		.scroll-container { scroll-snap-type: none; }
		.text-panel { padding: 1.5rem; }
		.hero-image-container { max-width: 280px; }
		.scroll-nav { display: none; }
		.cart-floating { position: static; width: 100%; margin-top: 2rem; }
		.landing-tagline { font-size: 2.5rem; }
		.hero-logo { width: 220px; }
		.sticky-header { top: 1rem; left: 1.5rem; }
		.sticky-logo { width: 60px; }
	}
</style>
